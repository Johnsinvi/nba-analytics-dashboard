{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "line_pts_trend",
  "position": { "x": 20, "y": 130, "z": 1000, "height": 250, "width": 1240, "tabOrder": 5000 },
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": { "SourceRef": { "Entity": "game_log" } },
                  "Property": "Date"
                }
              },
              "queryRef": "game_log.Date",
              "nativeQueryRef": "Date",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": { "Expression": { "SourceRef": { "Entity": "Measures" } }, "Property": "Avg Game Points" }
              },
              "queryRef": "Measures.Avg Game Points",
              "nativeQueryRef": "Avg Points"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Column": {
                "Expression": { "SourceRef": { "Entity": "game_log" } },
                "Property": "Date"
              }
            },
            "direction": "Ascending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "objects": {
      "lineStyles": [{ "properties": { "areaShow": { "expr": { "Literal": { "Value": "true" } } }, "lineChartType": { "expr": { "Literal": { "Value": "'smooth'" } } } } }],
      "valueAxis": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "showAxisTitle": { "expr": { "Literal": { "Value": "false" } } } } }],
      "categoryAxis": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "showAxisTitle": { "expr": { "Literal": { "Value": "false" } } } } }],
      "dataPoint": [{ "properties": { "defaultColor": { "solid": { "color": { "expr": { "Literal": { "Value": "'#1D428A'" } } } } } } }]
    },
    "visualContainerObjects": {
      "title": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "text": { "expr": { "Literal": { "Value": "'Points Scored Trend by Date'" } } }, "fontSize": { "expr": { "Literal": { "Value": "12D" } } }, "bold": { "expr": { "Literal": { "Value": "true" } } } } }],
      "background": [{ "properties": { "show": { "expr": { "Literal": { "Value": "true" } } }, "color": { "solid": { "color": { "expr": { "Literal": { "Value": "'#F5F5F5'" } } } } }, "transparency": { "expr": { "Literal": { "Value": "0D" } } } } }]
    },
    "drillFilterOtherVisuals": true
  }
}
