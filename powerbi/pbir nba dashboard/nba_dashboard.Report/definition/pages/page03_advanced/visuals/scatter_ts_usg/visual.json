{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.5.0/schema.json",
  "name": "scatter_ts_usg",
  "position": { "x": 620, "y": 130, "z": 1000, "height": 560, "width": 640, "tabOrder": 6000 },
  "visual": {
