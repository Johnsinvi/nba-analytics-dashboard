model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["GitHubRawBaseURL","player_stats","team_standings","game_log","advanced_stats","_Measures"]

annotation PBI_ProTooling = ["DevMode"]

ref table player_stats
ref table team_standings
ref table game_log
ref table advanced_stats
ref table _Measures

ref cultureInfo en-US

