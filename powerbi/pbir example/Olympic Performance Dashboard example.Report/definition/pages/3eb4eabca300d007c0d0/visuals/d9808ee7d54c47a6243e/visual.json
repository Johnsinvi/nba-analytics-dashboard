              },
              {
                "textRuns": [
                  {
                    "value": "hosts - ",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontFamily": "Segoe UI",
                      "fontSize": "12pt"
                    }
                  },
                  {
                    "value": "Contains the metadata for each Olympic Games, including the host city, country, season (Summer/Winter), and the official start/end dates. This lets you tie athlete results back to a specific Games.",
