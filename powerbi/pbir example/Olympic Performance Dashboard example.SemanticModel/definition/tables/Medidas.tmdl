			=====================*/
			
			.cardTitle{
			  width:100%;
			  text-align:center;
			
			  font-size:10px;
			  font-weight:900;
			  color:#dc2626;
			
			  text-transform:uppercase;
			
			  padding-bottom:2px;
			  margin-bottom:3px;
			
			  border-bottom:2px solid #dc2626;
			}
			
			
			/* =====================
