			  color:#6b7280;
			  padding:4px;
			  background:#e5e7eb;
			}
			
			
			/* =====================
			   ANIMATION
			=====================*/
			
			@keyframes scrollLoop{
			
			  0%{ transform:translateX(0); }
			
			  100%{ transform:translateX(-50%); }
			
			}
			
			</style>
			
			
			<div class='carouselBox'>
			
			
			<!-- HEADER -->
			<div class='carouselHeader'>
			
			<div class='carouselTitle'>
			📰 Olympic Athletes — Top Performers
			</div>
			
			<div class='carouselBadge'>LIVE</div>
			
			</div>
			
			
			<!-- CAROUSEL -->
			<div class='carousel'>
			
			<div class='track'>
			
			" & _Cards & _Cards & "
			
			</div>
			
			</div>
			
			
			</div>
			"
			
