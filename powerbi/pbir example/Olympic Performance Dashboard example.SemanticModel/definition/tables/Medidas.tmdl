	measure 'Athlete Spotlight Vertical v6 HD' = ```
			
			
			
			/* =====================
			   SELECTED ATHLETE
			=====================*/
			
			VAR _Athlete =
			SELECTEDVALUE(athletes[Athlete])
			
			VAR _AthleteURL =
			SELECTEDVALUE(athletes[Athlete URL])
			
			VAR _Bio =
			SELECTEDVALUE(athletes[Bio])
			
			
			
			/* =====================
			   FORCE CONTEXT
			=====================*/
			
			VAR _AthleteFilter =
			TREATAS(
			    VALUES(athletes[Athlete URL]),
			    results[athlete_url]
			)
			
			
			
			/* =====================
			   METRICS
			=====================*/
			
			VAR _Score =
			CALCULATE(
			    [Medal Score],
			    _AthleteFilter
			)
			
			
			VAR _Total =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    _AthleteFilter
			)
			
			
			VAR _Games =
			CALCULATE(
			    DISTINCTCOUNT(results[Game Slug]),
			    _AthleteFilter
			)
			
			
			VAR _Discipline =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    _AthleteFilter
			)
			
			
			VAR _Country =
			CALCULATE(
			    SELECTEDVALUE(results[Country]),
			    _AthleteFilter
			)
			
			
			
			/* =====================
			   FLAG
			=====================*/
			
			VAR _Flag =
			CALCULATE(
			    MAX(countrys[Flag_URL]),
			    _AthleteFilter
			)
			
			
			
			/* =====================
			   MEDALS
			=====================*/
			
			VAR _Gold =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    'athlete medals'[Medal] = "Gold",
			    _AthleteFilter
			)
			
			
			VAR _Silver =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    'athlete medals'[Medal] = "Silver",
			    _AthleteFilter
			)
			
			
			VAR _Bronze =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    'athlete medals'[Medal] = "Bronze",
			    _AthleteFilter
			)
			
			
			
			/* =====================
			   FORMAT
			=====================*/
			
			VAR _FmtScore = FORMAT(_Score,"#,##0")
			VAR _FmtTotal = FORMAT(_Total,"#,0")
			VAR _FmtGames = FORMAT(_Games,"0")
			
			VAR _BioFinal =
			IF(
			    NOT ISBLANK(_Bio),
			    _Bio,
			    "No biography available."
			)
			
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   SPOTLIGHT CARD 440x300
			=====================*/
			
			.cardBox{
			  width:100%;
			  max-width:300px;
			  min-width:240px;
			
			  height:440px;
			
			  background:transparent;
			
			  border-radius:22px;
			  border:1px solid rgba(255,255,255,0.25);
			
			  padding:14px 14px 12px;
			
			  box-shadow:none;
			
			  font-family:Segoe UI, Inter, Arial;
			
			  display:flex;
			  flex-direction:column;
			  align-items:center;
			  justify-content:space-between;
			
			  box-sizing:border-box;
			}
			
			
			/* =====================
			   PHOTO
			=====================*/
			
			.photoWrap{
			  width:120px;
			  height:120px;
			
			  border-radius:50%;
			  background:rgba(241,245,249,0.3);
			
			  display:flex;
			  justify-content:center;
			  align-items:center;
			
			  margin-bottom:6px;
			
			  border:3px solid #dc2626;
			}
			
			.photoWrap img{
			  width:92%;
			  height:92%;
			  border-radius:50%;
			  object-fit:cover;
			}
			
			
			/* =====================
			   NAME
			=====================*/
			
			.name{
			  font-size:20px;
			  font-weight:900;
			  color:#111827;
			  text-align:center;
			
			  line-height:1.2;
			}
			
			
			/* =====================
			   COUNTRY
			=====================*/
			
			.country{
			  display:flex;
			  align-items:center;
			  gap:6px;
			
			  font-size:13px;
			  font-weight:700;
			
			  color:#374151;
			}
			
			.flag{
			  width:22px;
			  height:15px;
			
			  border-radius:2px;
			  border:1px solid rgba(0,0,0,0.15);
			}
			
			
			/* =====================
			   DISCIPLINE
			=====================*/
			
			.discipline{
			  font-size:12px;
			
			  background:rgba(248,250,252,0.6);
			  border:1px solid rgba(229,231,235,0.4);
			
			  border-radius:10px;
			  padding:5px 10px;
			
			  color:#374151;
			
			  text-align:center;
			}
			
			
			/* =====================
			   KPI
			=====================*/
			
			.kpiRow{
			  display:flex;
			  justify-content:space-between;
			  width:100%;
			  gap:6px;
			}
			
			.kpi{
			  text-align:center;
			  flex:1;
			}
			
			.kpiVal{
			  font-size:19px;
			  font-weight:900;
			  color:#111827;
			}
			
			.kpiLab{
			  font-size:10px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   BIO
			=====================*/
			
			.bioBox{
			  width:100%;
			
			  background:rgba(249,250,251,0.6);
			  border:1px solid rgba(229,231,235,0.4);
			
			  border-radius:12px;
			
			  padding:9px 10px;
			
			  font-size:11px;
			  color:#374151;
			  line-height:1.45;
			
			  flex:1;
			
			  overflow-y:auto;
			
			  box-sizing:border-box;
			}
			
			
			/* =====================
			   MEDALS
			=====================*/
			
			.medals{
			  display:flex;
			  gap:12px;
			
			  font-size:19px;
			  font-weight:800;
			}
			
			.gold{ color:#facc15; }
			.silver{ color:#9ca3af; }
			.bronze{ color:#fb923c; }
			
			
			/* =====================
			   RESPONSIVE
			=====================*/
			
			@media(max-width:500px){
			
			  .cardBox{
			    max-width:260px;
			    height:400px;
			  }
			
			  .photoWrap{
			    width:100px;
			    height:100px;
			  }
			
			  .name{
			    font-size:18px;
			  }
			
			}
			
			</style>
			
			
			<div class='cardBox'>
			
			
			<!-- PHOTO -->
			
			<div class='photoWrap'>
			<img src='" & _AthleteURL & "'/>
			</div>
			
			
			<!-- NAME -->
			
			<div class='name'>" & _Athlete & "</div>
			
			
			<!-- COUNTRY -->
			
			<div class='country'>
			<img class='flag' src='" & _Flag & "'/>
			" & _Country & "
			</div>
			
			
			<!-- DISCIPLINE -->
			
			<div class='discipline'>
			" & _Discipline & "
			</div>
			
			
			<!-- KPIs -->
			
			<div class='kpiRow'>
			
			
			<div class='kpi'>
			<div class='kpiVal'>" & _FmtScore & "</div>
			<div class='kpiLab'>Score</div>
			</div>
			
			
			<div class='kpi'>
			<div class='kpiVal'>" & _FmtGames & "</div>
			<div class='kpiLab'>Games</div>
			</div>
			
			
			<div class='kpi'>
			<div class='kpiVal'>" & _FmtTotal & "</div>
			<div class='kpiLab'>Medals</div>
			</div>
			
			
			</div>
			
			
			<!-- BIO -->
			
			<div class='bioBox'>
			" & _BioFinal & "
			</div>
			
			
			<!-- MEDALS -->
			
			<div class='medals'>
			
			<span class='gold'>🥇 " & _Gold & "</span>
			<span class='silver'>🥈 " & _Silver & "</span>
			<span class='bronze'>🥉 " & _Bronze & "</span>
			
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash 3
		lineageTag: a0543167-443d-4f63-87e9-9fb7b944375e

