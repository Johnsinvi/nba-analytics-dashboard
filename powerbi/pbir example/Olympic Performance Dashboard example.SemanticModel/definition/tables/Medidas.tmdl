	measure 'Olympic Tooltip Mini Trend HTML' = ```
			
			
			VAR _Data =
			
			TOPN(
			    12,
			    SUMMARIZE(
			        calendar,
			        calendar[Year],
			        "Score", [Medal Score]
			    ),
			    calendar[Year],
			    DESC
			)
			
			VAR _Min =
			MINX(_Data,[Score])
			
			VAR _Max =
			MAXX(_Data,[Score])
			
			VAR _Range =
			IF(_Max-_Min=0,1,_Max-_Min)
			
			
			VAR _Points =
			
			CONCATENATEX(
			
			    _Data,
			
			    VAR _X =
			        FORMAT(
			            DIVIDE(
			                RANKX(_Data,calendar[Year],,ASC)-1,
			                COUNTROWS(_Data)-1
			            )*100,
			        "0.0"
			        )
			
			    VAR _Y =
			        FORMAT(
			            100 -
			            DIVIDE(
			                [Score]-_Min,
			                _Range
			            )*100,
			        "0.0"
			        )
			
			    RETURN
			
			    _X & "," & _Y,
			
			    " "
			
			)
			
			RETURN
			
			"
			<svg
			 width='300'
			 height='40'
			 viewBox='0 0 100 100'
			 preserveAspectRatio='none'
			 style='margin-top:4px;'
			>
			
			<!-- Background -->
			<rect
			 x='0' y='0'
			 width='100' height='100'
			 fill='#f8fafc'
			 rx='6'
			/>
			
			<!-- Line -->
			<polyline
			 fill='none'
			 stroke='#dc2626'
			 stroke-width='3'
			 stroke-linecap='round'
			 stroke-linejoin='round'
			 points='" & _Points & "'
			/>
			
			<!-- Glow -->
			<polyline
			 fill='none'
			 stroke='#fca5a5'
			 stroke-width='6'
			 opacity='0.3'
			 points='" & _Points & "'
			/>
			
			</svg>
			"
			
			```
		displayFolder: Dash 2
		lineageTag: 5867e78c-fc55-401d-aa8a-dc44658cf85c

	measure 'Country Comparison Title' = ```
			
			
			VAR _Season =
			SELECTEDVALUE(
			    hosts[Season],
			    "All Seasons"
			)
			
			VAR _MinYear =
			MIN(hosts[Year])
			
			VAR _MaxYear =
			MAX(hosts[Year])
			
			VAR _Period =
			IF(
			    _MinYear = _MaxYear,
			    FORMAT(_MinYear,"0"),
			    FORMAT(_MinYear,"0") & "–" & FORMAT(_MaxYear,"0")
			)
			
			RETURN
			
			"🌍 Country Performance Comparison — " &
			_Season & " (" & _Period & ")"
			
			```
