	measure 'Flip Card Efficiency' = ```
			
			VAR _Athlete =
			CALCULATE(
			SELECTEDVALUE(athletes[Athlete]),
			TOPN(1,ALL(athletes[Athlete]),[Total Medals],DESC)
			)
			
			VAR _Medals =
			CALCULATE(
			[Total Medals],
			athletes[Athlete]=_Athlete
			)
			
			VAR _Games =
			CALCULATE(
			DISTINCTCOUNT(results[Game Slug]),
			results[athlete_full_name]=_Athlete
			)
			
			VAR _Eff =
			FORMAT(
			DIVIDE(_Medals,_Games),
			"0.0"
			)
			
			RETURN
			
