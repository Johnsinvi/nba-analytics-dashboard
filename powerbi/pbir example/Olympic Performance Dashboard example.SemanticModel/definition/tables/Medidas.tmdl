		annotation 277cc1b9-af89-4597-8e15-cacc25c0886b = Para usar caracteres especiais em um nome de medida, coloque todo o nome entre colchetes ( [] ) e adicione ] a quaisquer colchetes de fechamento no nome.

	measure 'Olympic Athlete Cards ESPN FINAL v7' = ```
			
			
			VAR BaseTable =
			
			FILTER(
			
			    ADDCOLUMNS(
			
			        SUMMARIZE(
			            results,
			            results[athlete_full_name],
			            results[NOC],
			            results[Country],
			            results[athlete_url]
			        ),
			
			
			        /* TOTAL MEDALS */
			        "TotalMedals",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] IN {"Gold","Silver","Bronze"}
			        ),
			
			
			        /* GOLD */
			        "Gold",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Gold"
			        ),
			
			
			        /* SILVER */
			        "Silver",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Silver"
			        ),
			
			
			        /* BRONZE */
			        "Bronze",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Bronze"
			        ),
			
			
			        /* LAST YEAR */
			        "LastYear",
			        CALCULATE(
			            MAX(hosts[Year])
			        ),
			
			
			        /* MAIN SPORT */
			        "MainSport",
			
			        VAR A = SELECTEDVALUE(results[athlete_full_name])
			
			        VAR T =
			
			            SUMMARIZE(
			                FILTER(
			                    results,
			                    results[athlete_full_name] = A
			                ),
			                results[Discipline],
			                "Qtd", COUNTROWS(results)
			            )
			
			        RETURN
			            MAXX(TOPN(1,T,[Qtd],DESC),[Discipline]),
			
			
			        /* BIO (Bridge Safe) */
			        "Bio",
			        CALCULATE(
			            MAX(athletes[Bio]),
			            TREATAS(
			                VALUES(results[athlete_url]),
			                athletes[Athlete URL]
			            )
			        ),
			
			
			        /* FLAG */
			        "Flag",
			        SWITCH(
			            results[NOC],
			            "USA","🇺🇸","BRA","🇧🇷","GER","🇩🇪","FRA","🇫🇷","GBR","🇬🇧",
			            "CHN","🇨🇳","JPN","🇯🇵","ITA","🇮🇹","ESP","🇪🇸","AUS","🇦🇺",
			            "CAN","🇨🇦","KOR","🇰🇷","NED","🇳🇱","NOR","🇳🇴","SWE","🇸🇪",
			            "🏳️"
			        )
			
			    ),
			
			    NOT ISBLANK(results[athlete_full_name]) &&
			    results[athlete_full_name] <> ""
			
			)
			
			
			VAR TopAthletes =
			    TOPN(20,BaseTable,[TotalMedals],DESC)
			
			
			VAR Cards =
			
			CONCATENATEX(
			
			    TopAthletes,
			
			"
			
			<a href='https://www.olympics.com" & [athlete_url] & "'
			   target='_blank'
			   class='cardLink'>
			
			
			<div class='card'>
			
			
			<!-- FRONT -->
			<div class='front tooltipWrap'>
			
			
			<div class='tooltipBox'>
			<b>Bio</b><br/>
			" & LEFT([Bio],320) & "...
			</div>
			
			
			<div class='name'>
			" & [athlete_full_name] & "
			</div>
			
			
			<div class='sport'>
			" & IF(ISBLANK([MainSport]),"Multiple Sports",[MainSport]) & "
			</div>
			
			
			<div class='country'>
			" & [Flag] & " " & [Country] & "
			</div>
			
			
			<div class='medal'>
			🏅 " & [TotalMedals] & "
			</div>
			
			
			<div class='year'>
			Last Games: " & [LastYear] & "
			</div>
			
			
			</div>
			
			
			<!-- BACK -->
			<div class='back'>
			
			
			<div class='backHeader'>
			ATHLETE STATS
			</div>
			
			
			<div class='backBody'>
			
			<div>🥇 Gold: " & [Gold] & "</div>
			<div>🥈 Silver: " & [Silver] & "</div>
			<div>🥉 Bronze: " & [Bronze] & "</div>
			<div>🏟️ Main: " & [MainSport] & "</div>
			
			</div>
			
			
			<div class='backFooter'>
			Official Olympic Profile
			</div>
			
			
			</div>
			
			
			</div>
			
			</a>
			
			",
			
			"")
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   GROUP TITLE
			=====================*/
			
			.groupTitle{
			  font-size:22px;
			  font-weight:900;
			  color:#111827;
			  margin-bottom:6px;
			}
			
			.groupSub{
			  font-size:13px;
			  color:#6b7280;
			  margin-bottom:12px;
			}
			
			
			/* =====================
			   AUTO SCROLL
			=====================*/
			
			.scrollOuter{
			  overflow-x:auto;
			  width:100%;
			}
			
			.scrollWrap{
			  display:flex;
			  gap:14px;
			  padding:6px;
			  width:max-content;
			
			  animation:autoScroll 90s linear infinite;
			}
			
			.scrollOuter:hover .scrollWrap{
			  animation-play-state:paused;
			}
			
			
			@keyframes autoScroll{
			  from{ transform:translateX(0); }
			  to{ transform:translateX(-50%); }
			}
			
			
			/* Scrollbar */
			
			.scrollOuter::-webkit-scrollbar{
			  height:6px;
			}
			
			.scrollOuter::-webkit-scrollbar-thumb{
			  background:#dc2626;
			  border-radius:10px;
			}
			
			
			/* =====================
			   LINK
			=====================*/
			
			.cardLink{
			  text-decoration:none;
			  color:inherit;
			}
			
			
			/* =====================
			   CARD
			=====================*/
			
			.card{
			  width:210px;
			  height:175px;
			
			  background:#ffffff;
			  border-radius:14px;
			  border:1px solid #e5e7eb;
			
			  box-shadow:0 3px 10px rgba(0,0,0,.12);
			
			  position:relative;
			  overflow:hidden;
			
			  transition:.3s;
			}
			
			.card:hover{
			  transform:translateY(-4px);
			  box-shadow:0 10px 22px rgba(0,0,0,.18);
			}
			
			
			/* FRONT */
			
			.front{
			  padding:12px;
			
			  height:100%;
			
			  display:flex;
			  flex-direction:column;
			  justify-content:space-between;
			}
			
			.name{
			  font-size:14px;
			  font-weight:900;
			  color:#111827;
			
			  white-space:nowrap;
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			.sport{
			  font-size:12px;
			  font-weight:800;
			  color:#2563eb;
			}
			
			.country{
			  font-size:12px;
			  font-weight:700;
			  color:#374151;
			}
			
			.medal{
			  background:#fee2e2;
			  color:#dc2626;
			
			  font-size:12px;
			  font-weight:900;
			
			  padding:4px 7px;
			  border-radius:7px;
			
			  width:fit-content;
			}
			
			.year{
			  font-size:11px;
			  color:#6b7280;
			}
			
			
			/* BACK */
			
			.back{
			  position:absolute;
			  bottom:-100%;
			  width:100%;
			  height:100%;
			
			  background:#f8fafc;
			
			  padding:12px;
			
			  transition:.4s ease;
			
			  border-top:3px solid #dc2626;
			}
			
			.card:hover .back{
			  bottom:0;
			}
			
			.backHeader{
			  background:#dc2626;
			  color:white;
			
			  font-size:11px;
			  font-weight:900;
			
			  padding:4px;
			  border-radius:6px;
			
			  text-align:center;
			}
			
			.backBody{
			  font-size:12px;
			  line-height:1.5;
			}
			
			.backFooter{
			  font-size:9px;
			  color:#6b7280;
			  text-align:center;
			  margin-top:4px;
			}
			
			
			/* =====================
			   TOOLTIP
			=====================*/
			
			.tooltipWrap{
			  position:relative;
			}
			
			.tooltipBox{
			  position:absolute;
			
			  bottom:115%;
			  left:50%;
			  transform:translateX(-50%);
			
			  width:260px;
			
			  background:#111827;
			  color:#f9fafb;
			
			  padding:10px 12px;
			
			  border-radius:10px;
			
			  font-size:11px;
			  line-height:1.5;
			
			  box-shadow:0 8px 20px rgba(0,0,0,.35);
			
			  opacity:0;
			  pointer-events:none;
			
			  transition:.25s ease;
			
			  z-index:50;
			}
			
			.tooltipBox:after{
			  content:'';
			  position:absolute;
			
			  top:100%;
			  left:50%;
			  transform:translateX(-50%);
			
			  border-width:6px;
			  border-style:solid;
			  border-color:#111827 transparent transparent transparent;
			}
			
			.tooltipWrap:hover .tooltipBox{
			  opacity:1;
			}
			
			</style>
			
			
			<!-- TITLE -->
			<div>
			
			<div class='groupTitle'>
			🏅 Top Olympic Athletes
			</div>
			
			<div class='groupSub'>
			Leading medalists across Olympic history
			</div>
			
			</div>
			
			
			<div class='scrollOuter'>
			
			<div class='scrollWrap'>
			
			" & Cards & Cards & "
			
			</div>
			
			</div>
			"
			
			```
