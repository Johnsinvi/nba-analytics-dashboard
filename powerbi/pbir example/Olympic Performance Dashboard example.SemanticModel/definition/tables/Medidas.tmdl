	measure 'Flip Card Global Share' = ```
			
			VAR _Country =
			CALCULATE(
			SELECTEDVALUE(results[NOC]),
			TOPN(1,ALL(results[NOC]),[Medal Score],DESC)
			)
			
			VAR _Share =
			FORMAT(
			DIVIDE(
			CALCULATE([Total Medals],results[NOC]=_Country),
			[Total Medals]
			),
			"0.0%"
			)
			
			RETURN
			
			"
			<style>
			
			/* ===== FLIP ENGINE ===== */
			
			.flipCard{width:220px;height:140px;perspective:1200px;}
