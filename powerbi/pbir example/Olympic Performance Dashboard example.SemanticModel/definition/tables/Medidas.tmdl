	measure 'Olympic Banner Cards Final Clean Broadcast' = ```
			
			VAR _Total = FORMAT([Total Medals], "#,0")
			
			VAR _Country =
			    CALCULATE(
			        SELECTEDVALUE(results[NOC]),
			        TOPN(1,ALL(results[NOC]),[Medal Score],DESC)
			    )
			
			VAR _Score =
			    CALCULATE([Medal Score],results[NOC]=_Country)
			
			VAR _Athlete =
			    CALCULATE(
			        SELECTEDVALUE(athletes[Athlete]),
			        TOPN(1,ALL(athletes[Athlete]),[Total Medals],DESC)
			    )
			
			VAR _Medals =
			    CALCULATE([Total Medals],athletes[Athlete]=_Athlete)
			
			VAR _Growth = [Medal Growth]
			
			VAR _Icon =
			    IF(_Growth>0.15,"🚀",
			    IF(_Growth<-0.1,"📉","➖"))
			
			VAR _TrendColor =
			    IF(_Growth>0.15,"#22c55e",
			    IF(_Growth<-0.1,"#ef4444","#38bdf8"))
			
			RETURN
			
			"
			<style>
			
			/* =========================
			   BROADCAST EFFECTS
			=========================*/
			
			@keyframes glowPulse {
			  0%   { box-shadow:0 0 6px rgba(56,189,248,.3); }
			  50%  { box-shadow:0 0 18px rgba(56,189,248,.8); }
			  100% { box-shadow:0 0 6px rgba(56,189,248,.3); }
			}
			
			@keyframes lineRun {
			  0%   { transform: translateX(-120%); opacity:0; }
			  20%  { opacity:1; }
			  80%  { opacity:1; }
			  100% { transform: translateX(120%); opacity:0; }
			}
			
			/* =========================
			   MAIN CARD
			=========================*/
			
			.cardBox {
			  position: relative;
			  border-radius: 16px;
			  overflow: hidden;
			  backdrop-filter: blur(6px);
			  background: linear-gradient(180deg,#020617,#020617,#020617);
			  box-shadow:0 0 18px rgba(56,189,248,0.35);
			  animation:glowPulse 5s ease-in-out infinite;
			}
			
			/* =========================
			   TOP LINE
			=========================*/
			
			.topLine {
			  position: absolute;
			  top: 0;
			  left: -40%;
			  height: 6px;
			  width: 60%;
			  background: linear-gradient(
			    90deg,
			    transparent,
			    #38bdf8,
			    #ffffff,
			    #38bdf8,
			    transparent
			  );
			  filter: drop-shadow(0 0 10px #38bdf8);
			  animation: lineRun 5s ease-in-out infinite;
			}
			
			/* =========================
			   WAVE DELAY
			=========================*/
			
			.card1 .topLine { animation-delay: 0s; }
			.card2 .topLine { animation-delay: 1.2s; }
			.card3 .topLine { animation-delay: 2.4s; }
			.card4 .topLine { animation-delay: 3.6s; }
			
			/* =========================
			   HEADERS
			=========================*/
			
			.cardTitle {
			  white-space: nowrap;
			  overflow: hidden;
			  text-overflow: ellipsis;
			  text-transform: uppercase;
			  letter-spacing: .6px;
			}
			
			/* =========================
			   TEXT
			=========================*/
			
			.cardValue {
			  color:#e5f3ff;
			}
			
			.cardSub {
			  color:#94a3b8;
			}
			
			</style>
			
			
			<div style='width:100%;font-family:Segoe UI;'>
			
			<!-- MAIN BANNER -->
			<div style='
			background:linear-gradient(90deg,#020617,#020617,#020617);
			border-radius:22px;
			padding:16px 20px;
			box-shadow:0 0 30px rgba(56,189,248,0.45);
			color:white;
			'>
			
			<!-- GRID -->
			<div style='display:grid;grid-template-columns:300px 1fr;gap:18px;align-items:center;'>
			
			<!-- LEFT -->
			<div>
			
			<div style='
			font-size:22px;
			font-weight:900;
			margin-bottom:4px;
			color:#38bdf8;
			text-shadow:0 0 8px rgba(56,189,248,.7);
			'>
			🏟️ OLYMPIC LIVE PERFORMANCE
			</div>
			
			<div style='
			font-size:13px;
			font-weight:600;
			opacity:0.9;
			color:#cbd5f5;
			'>
			GLOBAL OVERVIEW • 1896–2022
			</div>
			
			</div>
			
			
			<!-- CARDS -->
			<div style='display:flex;gap:14px;flex-wrap:wrap;'>
			
			
			<!-- TOTAL -->
			<div class='cardBox card1' style='flex:1 1 185px;'>
			
			<div class='topLine'></div>
			
			<div class='cardTitle'
			style='background:#0284c7;padding:7px;font-size:12px;font-weight:800;color:white;text-align:center;'>
			TOTAL MEDALS
			</div>
			
			<div style='padding:10px 12px;'>
			
			<div class='cardValue' style='font-size:28px;font-weight:900;'>" & _Total & "</div>
			<div class='cardSub' style='font-size:12px;'>All Games</div>
			
			</div>
			</div>
			
			
			<!-- COUNTRY -->
			<div class='cardBox card2' style='flex:1 1 185px;'>
			
			<div class='topLine'></div>
			
			<div class='cardTitle'
			style='background:#facc15;padding:7px;font-size:12px;font-weight:800;color:#020617;text-align:center;'>
			LEADING NATION
			</div>
			
			<div style='padding:10px 12px;'>
			
			<div class='cardValue' style='font-size:22px;font-weight:900;'>" & _Country & "</div>
			<div class='cardSub' style='font-size:12px;color:#22c55e;'>Score: " & FORMAT(_Score,"#,0") & "</div>
			
			</div>
			</div>
			
			
			<!-- ATHLETE -->
			<div class='cardBox card3' style='flex:1 1 185px;'>
			
			<div class='topLine'></div>
			
			<div class='cardTitle'
			style='background:#7c3aed;padding:7px;font-size:12px;font-weight:800;color:white;text-align:center;'>
			TOP ATHLETE
			</div>
			
			<div style='padding:10px 12px;'>
			
			<div class='cardValue' style='font-size:18px;font-weight:900;'>" & _Athlete & "</div>
			<div class='cardSub' style='font-size:12px;color:#a78bfa;'>" & FORMAT(_Medals,"#,0") & " Medals</div>
			
			</div>
			</div>
			
			
			<!-- MOMENTUM -->
			<div class='cardBox card4' style='flex:1 1 185px;'>
			
			<div class='topLine'></div>
			
			<div class='cardTitle'
			style='background:" & _TrendColor & ";padding:7px;font-size:12px;font-weight:800;color:white;text-align:center;'>
			MOMENTUM
			</div>
			
			<div style='padding:10px 12px;'>
			
			<div class='cardValue'
			style='font-size:24px;font-weight:900;color:" & _TrendColor & ";'>" &
