	measure 'Olympic Medal Table ESPN FINAL FLAGS v5' = ```
			
			
			/* =========================
			   BASE TABLE
			========================= */
			
			VAR _BaseTable =
			    SUMMARIZE(
			        'athlete medals',
			        'athlete medals'[NOC],
			
			        "Gold",
			            CALCULATE(
			                COUNTROWS('athlete medals'),
			                'athlete medals'[Medal] = "Gold"
			            ),
			
			        "Silver",
			            CALCULATE(
			                COUNTROWS('athlete medals'),
			                'athlete medals'[Medal] = "Silver"
			            ),
			
			        "Bronze",
			            CALCULATE(
			                COUNTROWS('athlete medals'),
			                'athlete medals'[Medal] = "Bronze"
			            ),
			
			        "Total",
			            COUNTROWS('athlete medals'),
			
			        "Score",
			            SUM('athlete medals'[Medal Value]),
			
			        /* PNG FLAG */
			        "Flag",
			            LOOKUPVALUE(
			                countrys[Flag_URL],
			                countrys[country_code],
			                MAX(results[country_code])
			            )
			    )
			
			
			/* =========================
			   RANK
			========================= */
			
			VAR _Table =
			    ADDCOLUMNS(
			        _BaseTable,
			
			        "Rank",
			        RANKX(
			            ALL('athlete medals'[NOC]),
			            CALCULATE( SUM('athlete medals'[Medal Value]) ),
			            ,
			            DESC,
			            DENSE
			        )
			    )
			
			
			/* =========================
			   HTML
			========================= */
			
			RETURN
			
			
			"
			<style>
			
			/* =========================
			   BASE
			========================= */
			
			.tableBox {
			  background:transparent;
			  border-radius:0;
			  padding:0;
			  border:none;
			  box-shadow:none;
			  font-family:Segoe UI;
			}
			
			
			/* =========================
			   HEADER SUPERIOR
			========================= */
			
			.tableHeader {
			  font-size:20px;
			  font-weight:900;
			
			  color:#000000; /* TÍTULO PRETO */
			
			  margin-bottom:6px;
			
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			
			  background:transparent;
			}
			
			.headerBadge {
			  background:#dc2626;
			  color:white;
			
			  font-size:11px;
			  font-weight:700;
			
			  padding:3px 7px;
			  border-radius:5px;
			}
			
			
			/* =========================
			   SCROLL
			========================= */
			
			.scrollBox {
			  max-height:430px;
			  overflow-y:auto;
			
			  background:transparent;
			  border:none;
			
			  position:relative;
			}
			
			
			/* =========================
			   TABLE
			========================= */
			
			table {
			  width:100%;
			  border-collapse:collapse;
			  font-size:13px;
			
			  background:transparent;
			}
			
			
			/* =========================
			   HEADER FIXO (PRETO)
			========================= */
			
			thead th {
			  background:rgba(255,255,255,0.8);
			
			  position:sticky;
			  top:0;
			  z-index:10;
			
			  padding:8px 6px;
			  text-align:left;
			
			  font-weight:900;
			  color:#000000;
			
			  backdrop-filter:blur(4px);
			
			  border-bottom:1px solid rgba(0,0,0,0.25);
			}
			
			
			/* =========================
			   CELLS
			========================= */
			
			td {
			  padding:7px 6px;
			
			  border-bottom:1px solid rgba(255,255,255,0.08);
			
			  background:transparent;
			
			  color:#e5e7eb;
			}
			
			
			/* =========================
			   HOVER
			========================= */
			
			tr:hover {
			  background:rgba(255,255,255,0.08);
			}
			
			
			/* =========================
			   PODIUM
			========================= */
			
			.rank1 { background:rgba(250,204,21,.18); }
			.rank2 { background:rgba(209,213,219,.15); }
			.rank3 { background:rgba(192,132,252,.18); }
			
			
			/* =========================
			   RANK (BRANCO)
			========================= */
			
			.rankCol {
			  font-weight:900;
			  color:#ffffff;
			  width:32px;
			}
			
			
			/* =========================
			   COUNTRY (BRANCO)
			========================= */
			
			.nocCol {
			  display:flex;
			  align-items:center;
			  gap:8px;
			
			  font-weight:800;
			  color:#ffffff;
			}
			
			
			/* =========================
			   FLAG
			========================= */
			
			.flagImg {
			  width:24px;
			  height:16px;
			
			  object-fit:cover;
			
			  border-radius:3px;
			
			  border:1px solid rgba(255,255,255,0.4);
			
			  box-shadow:0 1px 2px rgba(0,0,0,.25);
			}
			
			
			/* =========================
			   SCORE (PRETO)
			========================= */
			
			.scoreCol {
			  font-weight:900;
			  color:#000000;
			}
			
			</style>
			
			
			<div class='tableBox'>
			
			
			<!-- HEADER -->
			
			<div class='tableHeader'>
			
			<div>🏆 Medal Table</div>
			
			<div class='headerBadge'>LIVE</div>
			
			</div>
			
			
			<!-- TABLE -->
			
			<div class='scrollBox'>
			
			
			<table>
			
			
			<thead>
			<tr>
			
			  <th>#</th>
			  <th>Country</th>
			  <th>🥇</th>
			  <th>🥈</th>
			  <th>🥉</th>
			  <th>Total</th>
			  <th>Score</th>
			
			</tr>
			</thead>
			
			
			<tbody>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _Table,
			
			    VAR _Rank = [Rank]
			
			    VAR _Class =
			        IF(
			            _Rank = 1, "rank1",
			            IF(_Rank = 2, "rank2",
			            IF(_Rank = 3, "rank3",""))
			        )
			
			    RETURN
			
			
			"
			<tr class='" & _Class & "'>
			
			<td class='rankCol'>" & _Rank & "</td>
			
			<td class='nocCol'>
			
			<img class='flagImg' src='" & [Flag] & "'/>
			
			" & [NOC] & "
			
			</td>
			
			
			<td>" & [Gold] & "</td>
			<td>" & [Silver] & "</td>
			<td>" & [Bronze] & "</td>
			
			<td><b>" & [Total] & "</b></td>
			
			<td class='scoreCol'>" &
			FORMAT([Score],"#,0") &
			"</td>
			
			</tr>
			
			",
			
			"",
			
			[Rank], ASC
			
			)
			
			
			&
			
			
			"
			</tbody>
			
			
			</table>
			
			
			</div>
			
			
			</div>
			
			"
			
			```
