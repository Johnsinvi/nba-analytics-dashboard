	measure 'Olympic Legacy Header Page 5 FINAL' = ```
			
			
			
			/* =====================
			   CORE METRICS
			=====================*/
			
			VAR _GOAT =
			CALCULATE(
			    SELECTEDVALUE(athletes[Athlete]),
			    TOPN(1,ALL(athletes[Athlete]),[Medal Score],DESC)
			)
			
			VAR _GOATScore =
			CALCULATE(
			    [Medal Score],
			    athletes[Athlete]=_GOAT
			)
			
			
			VAR _TopNation =
			CALCULATE(
			    SELECTEDVALUE(results[Country]),
			    TOPN(1,ALL(results[Country]),[Medal Score],DESC)
			)
			
			VAR _TopNationScore =
			CALCULATE(
			    [Medal Score],
			    results[Country]=_TopNation
			)
			
			
			VAR _TopSport =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(1,ALL(results[Discipline]),[Total Medals],DESC)
			)
			
			
			VAR _GoldenEra =
			CALCULATE(
			    SELECTEDVALUE(calendar[Decade]),
			    TOPN(1,ALL(calendar[Decade]),[Medal Score],DESC)
			)
			
			
			
			/* =====================
			   WINTER / SUMMER
			=====================*/
			
			VAR _WinterMedals =
			CALCULATE(
			    [Total Medals],
			    hosts[Season] = "Winter"
			)
			
			VAR _SummerMedals =
			CALCULATE(
			    [Total Medals],
			    hosts[Season] = "Summer"
			)
			
			
			VAR _FmtWinter = FORMAT(_WinterMedals,"#,##0")
			VAR _FmtSummer = FORMAT(_SummerMedals,"#,##0")
			
			
			
			/* =====================
			   FORMAT
			=====================*/
			
			VAR _FmtGOAT = FORMAT(_GOATScore,"#,##0")
			VAR _FmtNation = FORMAT(_TopNationScore,"#,##0")
			
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   MASTER
			=====================*/
			
			.legacyBox{
			  width:100%;
			  background:white;
			
			  border-radius:20px;
			  border:1px solid #e5e7eb;
			
			  padding:clamp(12px,2vw,16px);
			
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  box-sizing:border-box;
			}
			
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.pageHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:flex-start;
			
			  gap:12px;
			  margin-bottom:14px;
			
			  flex-wrap:wrap;
			}
			
			
			.headerLeft{
			  display:flex;
			  flex-direction:column;
			}
			
			
			.mainTitle{
			  font-size:clamp(20px,3vw,24px);
			  font-weight:900;
			  color:#111827;
			
			  display:flex;
			  align-items:center;
			  gap:8px;
			}
			
			
			.badgeLive{
			  background:#dc2626;
			  color:white;
			
			  font-size:11px;
			  font-weight:800;
			
			  padding:3px 7px;
			  border-radius:5px;
			}
			
			
			.subTitle{
			  font-size:clamp(11px,2vw,12px);
			  color:#6b7280;
			  margin-top:2px;
			}
			
			
			
			/* =====================
			   SEASON BOX
			=====================*/
			
			.seasonWrap{
			  display:flex;
			  gap:14px;
			}
			
			
			.seasonBox{
			  text-align:right;
			  min-width:120px;
			}
			
			
			.seasonTitle{
			  font-size:10px;
			  font-weight:800;
			  color:#dc2626;
			  text-transform:uppercase;
			}
			
			
			.seasonValue{
			  font-size:16px;
			  font-weight:900;
			  color:#111827;
			}
			
			
			.seasonSub{
			  font-size:11px;
			  color:#6b7280;
			}
			
			
			
			/* =====================
			   GRID
			=====================*/
			
			.flipGrid{
			  display:grid;
			
			  grid-template-columns:
			  repeat(auto-fit,minmax(150px,1fr));
			
			  gap:10px;
			}
			
			
			
			/* =====================
			   CARD
			=====================*/
			
			.flipCard{
			  width:100%;
			  height:110px;
			  perspective:1000px;
			}
			
			
			.flipInner{
			  width:100%;
			  height:100%;
			
			  position:relative;
			
			  transition:transform .7s ease;
			  transform-style:preserve-3d;
			}
			
			
			.flipCard:hover .flipInner{
			  transform:rotateY(180deg);
			}
			
			
			
			/* Faces */
			
			.flipFront,
			.flipBack{
			  position:absolute;
			
			  width:100%;
			  height:100%;
			
			  backface-visibility:hidden;
			
			  border-radius:14px;
			
			  border:1px solid #e5e7eb;
			  background:white;
			
			  box-shadow:0 2px 6px rgba(0,0,0,.08);
			
			  padding:8px 10px;
			
			  box-sizing:border-box;
			
			  display:flex;
			  flex-direction:column;
			  justify-content:center;
			  align-items:center;
			
			  text-align:center;
			}
			
			
			.flipBack{
			  transform:rotateY(180deg);
			  background:#f8fafc;
			}
			
			
			
			/* Header */
			
			.cardHeader{
			  width:100%;
			
			  font-size:11px;
			  font-weight:900;
			
			  color:#dc2626;
			  text-transform:uppercase;
			
			  border-bottom:2px solid #dc2626;
			
			  padding-bottom:2px;
			  margin-bottom:4px;
			}
			
			
			
			/* Value */
			
			.cardValue{
			  font-size:clamp(16px,3vw,20px);
			  font-weight:900;
			  color:#111827;
			}
			
			
			.cardSub{
			  font-size:11px;
			  color:#6b7280;
			}
			
			
			
			/* Back */
			
			.backIcon{
			  font-size:18px;
			  margin-bottom:4px;
			}
			
			.backText{
			  font-size:11px;
			  color:#374151;
			  line-height:1.4;
			}
			
			</style>
			
			
			<div class='legacyBox'>
			
			
			<!-- HEADER -->
			
			<div class='pageHeader'>
			
			
			<!-- LEFT -->
			
			<div class='headerLeft'>
			
			
			<div class='mainTitle'>
			🌍 Olympic Legacy & Future
			<span class='badgeLive'>LIVE</span>
			</div>
			
			
			<div class='subTitle'>
			Icons • Dynasties • Next Chapters
			</div>
			
			
			</div>
			
			
			
			<!-- RIGHT -->
			
			<div class='seasonWrap'>
			
			
			<div class='seasonBox'>
			
			<div class='seasonTitle'>Winter</div>
			<div class='seasonValue'>" & _FmtWinter & "</div>
			<div class='seasonSub'>Total Medals</div>
			
			</div>
			
			
			<div class='seasonBox'>
			
			<div class='seasonTitle'>Summer</div>
			<div class='seasonValue'>" & _FmtSummer & "</div>
			<div class='seasonSub'>Total Medals</div>
			
			</div>
			
			
			</div>
			
			
			</div>
			
			
			
			<!-- KPI GRID -->
			
			<div class='flipGrid'>
			
			
			<!-- GOAT -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>GOAT</div>
			
			<div class='cardValue'>" & _GOAT & "</div>
			
			<div class='cardSub'>" & _FmtGOAT & " pts</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🐐</div>
			
			<div class='backText'>
			Greatest athlete in Olympic history based on total medal score.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			<!-- TOP NATION -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Top Nation</div>
			
			<div class='cardValue'>" & _TopNation & "</div>
			
			<div class='cardSub'>" & _FmtNation & " pts</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🏆</div>
			
			<div class='backText'>
			Most dominant country across all Olympic editions.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			<!-- ICONIC SPORT -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Iconic Sport</div>
			
			<div class='cardValue' style='font-size:14px;'>" & _TopSport & "</div>
			
			<div class='cardSub'>Most medals</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>⭐</div>
			
			<div class='backText'>
			Discipline that shaped Olympic history through medals and stars.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			<!-- GOLDEN ERA -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Golden Era</div>
			
			<div class='cardValue'>" & _GoldenEra & "s</div>
			
			<div class='cardSub'>Peak decade</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🕰️</div>
			
			<div class='backText'>
			Decade with the highest concentration of medal performance.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			</div>
			
			
			</div>
			"
			
			```
