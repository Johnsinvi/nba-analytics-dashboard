	measure 'Olympic KPI Flip Cards ESPN Clean v2' = ```
			
			
			VAR _Total = FORMAT([Total Medals], "#,0")
			
			VAR _Country =
			CALCULATE(
			    SELECTEDVALUE(results[NOC]),
			    TOPN(1,ALL(results[NOC]),[Medal Score],DESC)
			)
			
			VAR _Score =
			CALCULATE([Medal Score],results[NOC]=_Country)
			
			VAR _TopDiscipline =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(1,ALL(results[Discipline]),[Medal Score],DESC)
			)
			
			VAR _DisciplineScore =
			CALCULATE([Medal Score],results[Discipline]=_TopDiscipline)
			
			VAR _Growth = FORMAT([Medal Growth],"0.0%")
			
			RETURN
			
			"
			<style>
			
			/* =====================
			   GRID
			=====================*/
			
			.flipGrid{
			  display:grid;
			  grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
			  gap:12px;
			  width:100%;
			}
			
			/* =====================
			   CARD
			=====================*/
			
			.flipCard{
			  width:100%;
			  max-width:170px;
			  height:130px;
			  perspective:1000px;
			}
			
			.flipInner{
			  width:100%;
			  height:100%;
			  position:relative;
			  transition:transform .7s ease;
			  transform-style:preserve-3d;
			}
			
			.flipCard:hover .flipInner{
			  transform:rotateY(180deg);
			}
			
			/* Faces */
			
			.flipFront,
			.flipBack{
			  position:absolute;
			  width:100%;
			  height:100%;
			  backface-visibility:hidden;
			  border-radius:12px;
			  overflow:hidden;
			  border:1px solid #e5e7eb;
			  background:white;
			  box-shadow:0 2px 6px rgba(0,0,0,.08);
			  padding:8px 10px;
			}
			
			/* Back */
			
			.flipBack{
			  transform:rotateY(180deg);
			  background:#f8fafc;
			}
			
			/* =====================
			   HEADER
			=====================*/
			
			.cardHeader{
			  font-size:10px;
			  font-weight:800;
			  color:#dc2626;
			  text-transform:uppercase;
			  border-bottom:2px solid #dc2626;
			  padding-bottom:2px;
			  margin-bottom:4px;
			  letter-spacing:.3px;
			}
			
			/* =====================
			   CONTENT
			=====================*/
			
			.cardValue{
			  font-size:22px;
			  font-weight:900;
			  color:#111827;
			  line-height:1.1;
			}
			
			.cardSub{
			  font-size:11px;
			  color:#6b7280;
			  margin-top:3px;
			}
			
			/* Back */
			
			.backText{
			  font-size:11px;
			  color:#374151;
			  line-height:1.4;
			}
			
			.backIcon{
			  font-size:18px;
			  margin-bottom:4px;
			}
			
			</style>
			
			
			<div class='flipGrid'>
			
			
			<!-- TOTAL MEDALS -->
			<div class='flipCard'>
			<div class='flipInner'>
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Total Medals</div>
			
			<div class='cardValue'>" & _Total & "</div>
			<div class='cardSub'>All Games</div>
			
			</div>
			
			<div class='flipBack'>
			
			<div class='backIcon'>🏅</div>
			
			<div class='backText'>
			Total number of medals awarded across all Olympic editions, reflecting historical participation.
			</div>
			
			</div>
			
			</div>
			</div>
			
			
			<!-- LEADING NATION -->
			<div class='flipCard'>
			<div class='flipInner'>
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Leading Nation</div>
			
			<div class='cardValue'>" & _Country & "</div>
			<div class='cardSub'>Top Score</div>
			
			</div>
			
			<div class='flipBack'>
			
			<div class='backIcon'>🌍</div>
			
			<div class='backText'>
			Country with the highest weighted medal score, showing sustained Olympic dominance.
			</div>
			
			</div>
			
			</div>
			</div>
			
			
			<!-- TOP DISCIPLINE -->
			<div class='flipCard'>
			<div class='flipInner'>
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Top Discipline</div>
			
			<div class='cardValue' style='font-size:16px;'>" & _TopDiscipline & "</div>
			<div class='cardSub'>Score: " & FORMAT(_DisciplineScore,"#,0") & "</div>
			
			</div>
			
			<div class='flipBack'>
			
			<div class='backIcon'>🏟️</div>
			
			<div class='backText'>
			Sport discipline with the highest medal impact, highlighting competitive specialization.
			</div>
			
			</div>
			
			</div>
			</div>
			
			
			<!-- MEDAL SCORE -->
			<div class='flipCard'>
			<div class='flipInner'>
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Medal Score</div>
			
			<div class='cardValue'>" & FORMAT([Medal Score],"#,0") & "</div>
			<div class='cardSub'>Weighted Index</div>
			
			</div>
			
			<div class='flipBack'>
			
			<div class='backIcon'>📊</div>
			
			<div class='backText'>
			Weighted index based on Gold, Silver and Bronze medals to measure performance quality.
			</div>
			
			</div>
			
			</div>
			</div>
			
			
			<!-- MOMENTUM -->
			<div class='flipCard'>
			<div class='flipInner'>
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Momentum</div>
			
			<div class='cardValue'>" & _Growth & "</div>
			<div class='cardSub'>Recent Trend</div>
			
			</div>
			
			<div class='flipBack'>
			
			<div class='backIcon'>📈</div>
			
			<div class='backText'>
			Shows recent growth or decline in medal performance across Olympic cycles.
			</div>
			
			</div>
			
			</div>
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash 1
		lineageTag: 3305b25e-1428-4008-b890-44aae945658d

