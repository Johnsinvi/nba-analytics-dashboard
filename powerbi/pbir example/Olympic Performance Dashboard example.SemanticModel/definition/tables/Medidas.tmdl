	measure 'Card Leading Nation' = ```
			
			VAR _Country =
			    CALCULATE(
			        SELECTEDVALUE(results[NOC]),
			        TOPN(1, ALL(results[NOC]), [Medal Score], DESC)
			    )
			
			VAR _Score =
			    CALCULATE([Medal Score], results[NOC] = _Country)
			
			RETURN
			"<div style='background:#ffffff;border-radius:16px;padding:18px;box-shadow:0 4px 10px rgba(0,0,0,0.12);font-family:Segoe UI;'>" &
			"<div style='font-size:13px;color:#6b7280;'>🥇 Leading Nation</div>" &
			"<div style='font-size:28px;font-weight:700;color:#111827;'>" & _Country & "</div>" &
			"<div style='font-size:12px;color:#059669;'>Score: " & FORMAT(_Score,"#,0") & "</div>" &
			"</div>"
			
			```
		displayFolder: Dash 1
		lineageTag: 6731ec70-9b3e-40e3-a15c-554d16960a20

	measure 'Card Top Athlete' = ```
			
			VAR _Athlete =
			    CALCULATE(
			        SELECTEDVALUE(athletes[Athlete]),
			        TOPN(1, ALL(athletes[Athlete]), [Total Medals], DESC)
			    )
			
			VAR _Medals =
