	measure 'Atlhetes Comparison Title' = ```
			
			
			VAR _Season =
			SELECTEDVALUE(
			    hosts[Season],
			    "All Seasons"
			)
			
			VAR _MinYear =
			MIN(hosts[Year])
			
			VAR _MaxYear =
			MAX(hosts[Year])
			
			VAR _Period =
			IF(
			    _MinYear = _MaxYear,
			    FORMAT(_MinYear,"0"),
			    FORMAT(_MinYear,"0") & "–" & FORMAT(_MaxYear,"0")
			)
			
			RETURN
			
			"🌍 Athletes Performance Comparison — " &
			_Season & " (" & _Period & ")"
			
