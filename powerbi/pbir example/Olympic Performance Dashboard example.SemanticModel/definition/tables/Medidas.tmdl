	measure 'Olympic Countdown Live' = ```
			
			
			VAR _EventDate =
			    DATE(2026,2,6) + TIME(0,0,0)
			
			VAR _Now = NOW()
			
			VAR _Diff =
			    _EventDate - _Now
			
			VAR _Seconds =
			    INT(_Diff * 86400)
			
			VAR _Days =
			    INT(_Seconds / 86400)
			
			VAR _Hours =
			    INT(MOD(_Seconds,86400)/3600)
			
			VAR _Minutes =
			    INT(MOD(_Seconds,3600)/60)
			
			VAR _Secs =
			    MOD(_Seconds,60)
			
			RETURN
			
			IF(
			    _Seconds > 0,
			
			    "⏱️ " &
			    _Days & "d " &
			    FORMAT(_Hours,"00") & ":" &
			    FORMAT(_Minutes,"00") & ":" &
			    FORMAT(_Secs,"00"),
			
			    "🎉 Olympic Games Started!"
			)
			
			```
		displayFolder: Dash 1
		lineageTag: dbcbcbc3-05ec-49a0-b1a5-b38168bea1ab

