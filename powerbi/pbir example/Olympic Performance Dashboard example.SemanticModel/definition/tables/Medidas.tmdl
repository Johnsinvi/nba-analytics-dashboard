			</div>
			
			</div>
			
			
			<!-- ATHLETE -->
			<div class='cardBox card3' style='flex:1 1 185px;'>
			
			<div class='topLine' style='background:#8b5cf6;'></div>
			
			<div class='cardTitle'
			style='background:#8b5cf6;padding:7px;font-size:12px;font-weight:800;color:white;text-align:center;'>
			TOP ATHLETE
