		lineageTag: 9958f2af-82d9-417b-9209-4745b7a8adab

	measure 'Card Momentum' = ```
			
			VAR _Growth = [Medal Growth]
			
			VAR _Icon =
			    IF(_Growth > 0.15,"🚀",
			    IF(_Growth < -0.1,"📉","➖"))
			
			VAR _Color =
			    IF(_Growth > 0.15,"#059669",
			    IF(_Growth < -0.1,"#dc2626","#6b7280"))
			
			RETURN
			"<div style='background:#ffffff;border-radius:16px;padding:18px;box-shadow:0 4px 10px rgba(0,0,0,0.12);font-family:Segoe UI;'>" &
			"<div style='font-size:13px;color:#6b7280;'>Momentum</div>" &
			"<div style='font-size:26px;font-weight:700;color:" & _Color & ";'>" &
			_Icon & " " & FORMAT(_Growth,"0.0%") &
			"</div>" &
			"</div>"
			
			```
		displayFolder: Dash 1
		lineageTag: bbb52403-82fb-416f-ac5d-c6b49e674877

	measure 'Silver Medals' = ```
			
			CALCULATE(
			    COUNTROWS(results),
			    results[Medal (Raw)] = "Silver"
			)
			
			```
		formatString: 0
		displayFolder: Dash 1
		lineageTag: b9aeb953-7943-4286-89e0-34b37370d22e

	measure 'Medal Growth' = ```
			
			VAR CurrentYear =
			    MAX ( hosts[Year] )
			
			VAR PrevYear =
			    CurrentYear - 4
			
			VAR CurrentValue =
			    CALCULATE (
			        [Medal Score],
			        hosts[Year] = CurrentYear
			    )
			
			VAR PrevValue =
			    CALCULATE (
			        [Medal Score],
			        hosts[Year] = PrevYear
			    )
			
			RETURN
			DIVIDE ( CurrentValue - PrevValue, PrevValue )
			
			```
		displayFolder: Dash 1
		lineageTag: 073eedac-8187-4715-943f-689db77fbf0e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Card Narrative' = ```
			
			VAR _TopCountry =
			    CALCULATE(
			        SELECTEDVALUE(results[NOC]),
			        TOPN(1, ALL(results[NOC]), [Medal Score], DESC)
			    )
			
			VAR _Growth = [Medal Growth]
			
			VAR _Trend =
			    IF(
			        _Growth > 0.1, "accelerated growth",
			        IF(_Growth < -0.05, "performance decline", "stable performance")
			    )
			
			RETURN
			"<div style='background:#f9fafb;border-radius:14px;padding:16px;font-family:Segoe UI;'>" &
			"<div style='font-size:14px;font-weight:600;color:#111827;margin-bottom:6px;'>📊 Key Insight</div>" &
			"<div style='font-size:13px;color:#374151;line-height:1.5;'>" &
			"Over the last Olympic cycles, <b>" & _TopCountry & "</b> has demonstrated " &
			_Trend & ", reinforcing its position in global competition. " &
			"This trend highlights shifting dynamics in elite sports performance." &
			"</div></div>"
			
			```
		displayFolder: Dash 1
		lineageTag: 14353d68-b7dc-42d7-a50b-5e42b55c4623

	measure 'Olympic Header Cards' = ```
			
			VAR _Total = FORMAT([Total Medals], "#,0")
			
			VAR _Country =
			    CALCULATE(
			        SELECTEDVALUE(results[NOC]),
			        TOPN(1,ALL(results[NOC]),[Medal Score],DESC)
			    )
			
			VAR _Score =
			    CALCULATE([Medal Score],results[NOC]=_Country)
			
			VAR _Athlete =
			    CALCULATE(
			        SELECTEDVALUE(athletes[Athlete]),
			        TOPN(1,ALL(athletes[Athlete]),[Total Medals],DESC)
			    )
			
			VAR _Medals =
			    CALCULATE([Total Medals],athletes[Athlete]=_Athlete)
			
			VAR _Growth = [Medal Growth]
			
			VAR _Icon =
			    IF(_Growth>0.15,"🚀",
			    IF(_Growth<-0.1,"📉","➖"))
			
			VAR _Color =
			    IF(_Growth>0.15,"#059669",
			    IF(_Growth<-0.1,"#dc2626","#6b7280"))
			
			RETURN
			
			"<div style='display:flex;flex-wrap:wrap;gap:14px;width:100%;
			font-family:Segoe UI;'>
			
			<!-- TOTAL MEDALS -->
			<div style='flex:1 1 220px;min-width:200px;
			background:#ffffff;border-radius:18px;overflow:hidden;
			box-shadow:0 6px 14px rgba(0,0,0,0.15);'>
			
			<div style='background:linear-gradient(90deg,#2563eb,#0ea5e9);
			padding:10px;color:white;font-size:13px;font-weight:600;'>
			🏅 TOTAL MEDALS
			</div>
			
			<div style='padding:16px;'>
			<div style='font-size:34px;font-weight:800;color:#111827;'>" &
			_Total &
			"</div>
			<div style='font-size:12px;color:#6b7280;'>All Olympic Games</div>
			</div>
			</div>
			
			<!-- LEADING NATION -->
			<div style='flex:1 1 220px;min-width:200px;
			background:#ffffff;border-radius:18px;overflow:hidden;
			box-shadow:0 6px 14px rgba(0,0,0,0.15);'>
			
			<div style='background:linear-gradient(90deg,#f59e0b,#fbbf24);
			padding:10px;color:#111827;font-size:13px;font-weight:600;'>
			🥇 LEADING NATION
			</div>
			
			<div style='padding:16px;'>
			<div style='font-size:26px;font-weight:700;color:#111827;'>" &
			_Country &
			"</div>
			<div style='font-size:13px;color:#059669;'>
			Score: " & FORMAT(_Score,"#,0") & "
			</div>
			</div>
			</div>
			
			<!-- TOP ATHLETE -->
			<div style='flex:1 1 220px;min-width:200px;
			background:#ffffff;border-radius:18px;overflow:hidden;
			box-shadow:0 6px 14px rgba(0,0,0,0.15);'>
			
			<div style='background:linear-gradient(90deg,#7c3aed,#a78bfa);
			padding:10px;color:white;font-size:13px;font-weight:600;'>
			🏆 TOP ATHLETE
			</div>
			
			<div style='padding:16px;'>
			<div style='font-size:22px;font-weight:700;color:#111827;'>" &
			_Athlete &
			"</div>
			<div style='font-size:13px;color:#7c3aed;'>" &
			FORMAT(_Medals,"#,0") & " Medals
			</div>
			</div>
			</div>
			
			<!-- MOMENTUM -->
			<div style='flex:1 1 220px;min-width:200px;
			background:#ffffff;border-radius:18px;overflow:hidden;
			box-shadow:0 6px 14px rgba(0,0,0,0.15);'>
			
			<div style='background:" & _Color & ";
			padding:10px;color:white;font-size:13px;font-weight:600;'>
			MOMENTUM
			</div>
			
			<div style='padding:16px;'>
			<div style='font-size:26px;font-weight:700;color:" & _Color & ";'>" &
			_Icon & " " & FORMAT(_Growth,"0.0%") &
			"</div>
			<div style='font-size:12px;color:#6b7280;'>Cycle Trend</div>
			</div>
			</div>
			
			</div>"
			
			```
		displayFolder: Dash 1
		lineageTag: 4305a51c-423b-4992-aed7-de485be60116

