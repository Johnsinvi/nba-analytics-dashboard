	measure 'Tooltip Country Animated' = ```
			
			
			VAR _Country = SELECTEDVALUE(results[NOC])
			
			VAR _Total = FORMAT([Total Medals],"#,0")
			
			VAR _Score = FORMAT([Medal Score],"#,0")
			
			VAR _TopSport =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(1,ALL(results[Discipline]),[Medal Score],DESC)
			)
			
			VAR _TopAthlete =
			CALCULATE(
			    SELECTEDVALUE(athletes[Athlete]),
			    TOPN(1,ALL(athletes[Athlete]),[Total Medals],DESC)
			)
			
			RETURN
			
			"
			<style>
			
			/* =====================
			   ANIMATIONS
			=====================*/
			
			@keyframes fadeIn {
			  from { opacity:0; transform:translateY(8px); }
			  to   { opacity:1; transform:translateY(0); }
			}
			
			@keyframes glow {
			  0% { box-shadow:0 0 8px rgba(56,189,248,.3); }
			  50%{ box-shadow:0 0 18px rgba(56,189,248,.8); }
			  100%{ box-shadow:0 0 8px rgba(56,189,248,.3); }
			}
			
			/* =====================
			   CONTAINER
			=====================*/
			
			.ttBox{
			  width:260px;
			  background:rgba(2,6,23,.92);
			  border-radius:16px;
			  padding:14px;
			  color:#e5f3ff;
			  font-family:Segoe UI;
			  border:1px solid rgba(56,189,248,.5);
			  animation:fadeIn .35s ease, glow 4s infinite;
			}
			
			/* =====================
			   HEADER
			=====================*/
			
			.ttHeader{
			  font-size:18px;
			  font-weight:900;
			  color:#38bdf8;
			  margin-bottom:6px;
			  text-shadow:0 0 6px rgba(56,189,248,.8);
			}
			
			.ttSub{
			  font-size:11px;
			  color:#94a3b8;
			  margin-bottom:10px;
			}
			
			/* =====================
			   STATS
			=====================*/
			
			.statRow{
			  display:flex;
			  justify-content:space-between;
			  font-size:12px;
			  padding:4px 0;
			  border-bottom:1px solid rgba(148,163,184,.15);
			}
			
			.statRow:last-child{
			  border:none;
			}
			
			.statLabel{
			  color:#94a3b8;
			}
			
			.statValue{
			  font-weight:800;
			  color:#e5f3ff;
			}
			
			/* =====================
			   HIGHLIGHTS
			=====================*/
			
			.highlight{
			  background:rgba(56,189,248,.12);
			  border-radius:10px;
			  padding:8px;
			  margin-top:8px;
			}
			
			.hTitle{
			  font-size:11px;
			  font-weight:700;
			  color:#38bdf8;
			  margin-bottom:2px;
			}
			
			.hValue{
			  font-size:13px;
			  font-weight:800;
			}
			
			</style>
			
			
			<div class='ttBox'>
			
			<div class='ttHeader'>
			🏳️ " & _Country & "
			</div>
			
			<div class='ttSub'>
			Live Olympic Profile
			</div>
			
			
			<div class='statRow'>
			<span class='statLabel'>🏅 Total Medals</span>
			<span class='statValue'>" & _Total & "</span>
			</div>
			
			<div class='statRow'>
			<span class='statLabel'>📊 Medal Score</span>
			<span class='statValue'>" & _Score & "</span>
			</div>
			
			
			<div class='highlight'>
			
			<div class='hTitle'>🏆 Top Sport</div>
			<div class='hValue'>" & _TopSport & "</div>
			
			</div>
			
			
			<div class='highlight'>
			
			<div class='hTitle'>⭐ Top Athlete</div>
			<div class='hValue'>" & _TopAthlete & "</div>
			
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash 1
		lineageTag: bac3f45f-54a1-4fce-926e-62c9b84d76ed

