	measure 'Olympic Master Header ESPN Live v7' = ```
			
			
			/* =====================
			   CORE METRICS
			=====================*/
			
			VAR _Total = FORMAT([Total Medals], "#,0")
			
			VAR _Country =
			CALCULATE(
			    SELECTEDVALUE(results[NOC]),
			    TOPN(1,ALL(results[NOC]),[Medal Score],DESC)
			)
			
			VAR _Score =
			CALCULATE([Medal Score],results[NOC]=_Country)
			
			VAR _TopDiscipline =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(1,ALL(results[Discipline]),[Medal Score],DESC)
			)
			
			VAR _DisciplineScore =
			CALCULATE([Medal Score],results[Discipline]=_TopDiscipline)
			
			VAR _Growth = FORMAT([Medal Growth],"0.0%")
			
			VAR _Editions =
			DISTINCTCOUNT(hosts[Game Slug])
			
			
			/* =====================
			   COUNTDOWN — WINTER
			=====================*/
			
			VAR _WinterDate = DATE(2026,2,6)
			
			VAR _Now = NOW()
			
			VAR _DiffW = _WinterDate - _Now
			VAR _SecW = INT(_DiffW * 86400)
			
			VAR _DaysW = INT(_SecW / 86400)
			VAR _HoursW = INT(MOD(_SecW,86400)/3600)
			VAR _MinW = INT(MOD(_SecW,3600)/60)
			VAR _SecR = MOD(_SecW,60)
			
			VAR _ClockW =
			IF(
			    _SecW > 0,
			    FORMAT(_DaysW,"0") & "d " &
			    FORMAT(_HoursW,"00") & ":" &
			    FORMAT(_MinW,"00") & ":" &
			    FORMAT(_SecR,"00"),
			    "LIVE"
			)
			
			
			/* =====================
			   COUNTDOWN — SUMMER
			=====================*/
			
			VAR _SummerDate = DATE(2028,7,14)
			
			VAR _DiffS = _SummerDate - _Now
			VAR _SecS = INT(_DiffS * 86400)
			
			VAR _DaysS = INT(_SecS / 86400)
			VAR _HoursS = INT(MOD(_SecS,86400)/3600)
			VAR _MinS = INT(MOD(_SecS,3600)/60)
			VAR _SecS2 = MOD(_SecS,60)
			
			VAR _ClockS =
			IF(
			    _SecS > 0,
			    FORMAT(_DaysS,"0") & "d " &
			    FORMAT(_HoursS,"00") & ":" &
			    FORMAT(_MinS,"00") & ":" &
			    FORMAT(_SecS2,"00"),
			    "LIVE"
			)
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   MASTER
			=====================*/
			
			.masterBox{
			  width:100%;
			  background:#ffffff;
			  border-radius:16px;
			  border:1px solid #e5e7eb;
			
			  padding:10px 12px;
			
			  box-shadow:0 2px 6px rgba(0,0,0,.07);
			  font-family:Segoe UI;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.pageHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			
			  margin-bottom:8px;
			
			  flex-wrap:wrap;
			  gap:8px;
			}
			
			.headerLeft{
			  display:flex;
			  flex-direction:column;
			}
			
			.mainTitle{
			  font-size:17px;
			  font-weight:900;
			  color:#111827;
			
			  display:flex;
			  align-items:center;
			  gap:6px;
			}
			
			.badgeLive{
			  background:#dc2626;
			  color:white;
			
			  font-size:9px;
			  font-weight:800;
			
			  padding:2px 5px;
			  border-radius:4px;
			}
			
			.subTitle{
			  font-size:9px;
			  color:#6b7280;
			  margin-top:1px;
			}
			
			
			/* =====================
			   COUNTDOWN
			=====================*/
			
			.countWrap{
			  display:flex;
			  gap:10px;
			}
			
			.countBox{
			  text-align:right;
			  min-width:100px;
			}
			
			.countTitle{
			  font-size:8px;
			  font-weight:700;
			  color:#dc2626;
			  text-transform:uppercase;
			}
			
			.countTime{
			  font-size:12px;
			  font-weight:900;
			  color:#111827;
			}
			
			.countSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   GRID
			=====================*/
			
			.flipGrid{
			  display:grid;
			  grid-template-columns:repeat(auto-fit,minmax(120px,1fr));
			  gap:7px;
			}
			
			
			/* =====================
			   CARD
			=====================*/
			
			.flipCard{
			  width:100%;
			  height:73px;
			  perspective:1000px;
			}
			
			.flipInner{
			  width:100%;
			  height:100%;
			
			  position:relative;
			
			  transition:transform .6s ease;
			  transform-style:preserve-3d;
			}
			
			.flipCard:hover .flipInner{
			  transform:rotateY(180deg);
			}
			
			
			/* =====================
			   FACES
			=====================*/
			
			.flipFront,
			.flipBack{
			  position:absolute;
			
			  width:100%;
			  height:100%;
			
			  backface-visibility:hidden;
			
			  border-radius:10px;
			  overflow:hidden;
			
			  border:1px solid #e5e7eb;
			  background:white;
			
			  box-shadow:0 2px 5px rgba(0,0,0,.07);
			
			  padding:6px;
			
			  display:flex;
			  flex-direction:column;
			  justify-content:center;
			  align-items:center;
			
			  text-align:center;
			}
			
			.flipBack{
			  transform:rotateY(180deg);
			  background:#f8fafc;
			}
			
			
			/* =====================
			   HEADER CARD (LINHA FULL)
			=====================*/
			
			.cardHeader{
			  width:100%;                 /* ocupa todo o card */
			  text-align:center;
			
			  font-size:10px;
			  font-weight:900;
			  color:#dc2626;
			
			  text-transform:uppercase;
			
			  padding-bottom:2px;
			  margin-bottom:3px;
			
			  border-bottom:2px solid #dc2626; /* LINHA DE PONTA A PONTA */
			}
			
			
			/* =====================
			   CONTENT
			=====================*/
			
			.cardValue{
			  font-size:17px;
			  font-weight:900;
			  color:#111827;
			
			  margin:2px 0;
			}
			
			.cardSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   BACK
			=====================*/
			
			.backIcon{
			  font-size:14px;
			  margin-bottom:3px;
			}
			
			.backText{
			  font-size:9px;
			  color:#374151;
			  line-height:1.25;
			
			  text-align:center;
			}
			
			</style>
			
			
			<div class='masterBox'>
			
			
			<!-- HEADER -->
			<div class='pageHeader'>
			
			
			<!-- LEFT -->
			<div class='headerLeft'>
			
			<div class='mainTitle'>
			🏅 Olympic Performance Dashboard
			<span class='badgeLive'>LIVE</span>
			</div>
			
			<div class='subTitle'>
			Global Medal History • 1896–2022 • " & _Editions & " Editions
			</div>
			
			</div>
			
			
			<!-- RIGHT -->
			<div class='countWrap'>
			
			
			<!-- WINTER -->
			<div class='countBox'>
			
			<div class='countTitle'>Winter Games</div>
			
			<div class='countTime'>
			" & _ClockW & "
			</div>
			
			<div class='countSub'>
			Milano Cortina 2026
			</div>
			
			</div>
			
			
			<!-- SUMMER -->
			<div class='countBox'>
			
			<div class='countTitle'>Summer Games</div>
			
			<div class='countTime'>
			" & _ClockS & "
			</div>
			
			<div class='countSub'>
			Los Angeles 2028
			</div>
			
			</div>
			
			</div>
			
			
			</div>
			
			
			<!-- KPI GRID -->
			<div class='flipGrid'>
			
			
			<!-- TOTAL -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='cardHeader'>Total Medals</div>
			<div class='cardValue'>" & _Total & "</div>
			<div class='cardSub'>Across " & _Editions & " Editions</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>🏅</div>
			<div class='backText'>
			" & _Total & " medals across " & _Editions & " editions.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- COUNTRY -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='cardHeader'>Leading Nation</div>
			<div class='cardValue'>" & _Country & "</div>
			<div class='cardSub'>Score " & FORMAT(_Score,"#,0") & "</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>🌍</div>
			<div class='backText'>
			" & _Country & " leads with " & FORMAT(_Score,"#,0") & " points.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- DISCIPLINE -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='cardHeader'>Top Discipline</div>
			<div class='cardValue' style='font-size:14px;'>" & _TopDiscipline & "</div>
			<div class='cardSub'>Score " & FORMAT(_DisciplineScore,"#,0") & "</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>🏟️</div>
			<div class='backText'>
			" & _TopDiscipline & " contributes " & FORMAT(_DisciplineScore,"#,0") & " points.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- SCORE -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='cardHeader'>Medal Score</div>
			<div class='cardValue'>" & FORMAT([Medal Score],"#,0") & "</div>
			<div class='cardSub'>Weighted Index</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>📊</div>
			<div class='backText'>
			Quality-adjusted medal performance.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- MOMENTUM -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='cardHeader'>Momentum</div>
			<div class='cardValue'>" & _Growth & "</div>
			<div class='cardSub'>Recent Cycles</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>📈</div>
			<div class='backText'>
			Change of " & _Growth & " in recent cycles.
			</div>
			</div>
			
			</div></div>
			
			
			</div>
			
			</div>
			"
			
			```
		displayFolder: Dash 1
		lineageTag: 5d0e0dad-8a51-44b1-93b3-96ea45806b8a

