	measure 'Top Nation by Decade HTML FINAL v2' = ```
			
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			
			SUMMARIZE(
			
			    results,
			
			    calendar[Decade],
			    results[Country],
			
			    "Score",  [Medal Score],
			    "Total",  [Total Medals]
			
			)
			
			
			
			/* =====================
			   RANK BY DECADE
			=====================*/
			
			VAR _Ranked =
			
			ADDCOLUMNS(
			
			    _Base,
			
			    "Rank",
			
			    VAR _CurrentDecade = calendar[Decade]
			
			    RETURN
			
			    RANKX(
			
			        FILTER(
			            _Base,
			            calendar[Decade] = _CurrentDecade
			        ),
			
			        [Score],
			
			        ,
			
			        DESC,
			
			        DENSE
			    )
			)
			
			
			
			/* =====================
			   TOP 5
			=====================*/
			
			VAR _Top =
			
			FILTER(
			    _Ranked,
			    [Rank] <= 5
			)
			
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   ESPN TABLE
			=====================*/
			
			.tableBox{
			  width:100%;
			
			  background:#ffffff;
			
			  border-radius:16px;
			  border:1px solid #e5e7eb;
			
			  padding:10px 12px;
			
			  box-shadow:0 2px 6px rgba(0,0,0,.07);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  box-sizing:border-box;
			
			  display:flex;
			  flex-direction:column;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.tableHeader{
			  display:flex;
			  flex-direction:column;
			  gap:4px;
			
			  margin-bottom:8px;
			}
			
			.tableTitle{
			  font-size:17px;
			  font-weight:900;
			  color:#111827;
			}
			
			.tableSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   BADGE
			=====================*/
			
			.liveBadge{
			  background:#dc2626;
			  color:white;
			
			  font-size:9px;
			  font-weight:800;
			
			  padding:2px 5px;
			  border-radius:4px;
			
			  width:fit-content;
			}
			
			
			/* =====================
			   SCROLL (ONLY TABLE)
			=====================*/
			
			.scrollBox{
			  flex:1;
			
			  overflow-y:auto;
			
			  border-radius:12px;
			  border:1px solid #e5e7eb;
			
			  min-height:0;
			}
			
			
			/* =====================
			   TABLE
			=====================*/
			
			table{
			  width:100%;
			  border-collapse:collapse;
			  font-size:13px;
			}
			
			
			/* =====================
			   HEADER ROW
			=====================*/
			
			th{
			  position:sticky;
			  top:0;
			
			  background:#f1f5f9;
			
			  padding:8px 6px;
			
			  font-weight:800;
			  color:#374151;
			
			  border-bottom:1px solid #e5e7eb;
			
			  z-index:2;
			}
			
			
			/* =====================
			   CELLS
			=====================*/
			
			td{
			  padding:7px 6px;
			  border-bottom:1px solid #f1f5f9;
			}
			
			
			/* =====================
			   HOVER
			=====================*/
			
			tr:hover{
			  background:#f9fafb;
			}
			
			
			/* =====================
			   RANK
			=====================*/
			
			.rankCol{
			  font-weight:900;
			  color:#dc2626;
			  width:34px;
			}
			
			
			/* =====================
			   PODIUM
			=====================*/
			
			.rank1{ background:rgba(250,204,21,.15); }
			.rank2{ background:rgba(209,213,219,.18); }
			.rank3{ background:rgba(192,132,252,.15); }
			
			
			/* =====================
			   COUNTRY
			=====================*/
			
			.countryCol{
			  font-weight:700;
			  color:#111827;
			}
			
			
			/* =====================
			   SCORE
			=====================*/
			
			.scoreCol{
			  font-weight:900;
			  color:#16a34a;
			}
			
			
			/* =====================
			   RESPONSIVE
			=====================*/
			
			@media(max-width:600px){
			
			  table{
			    font-size:12px;
			  }
			
			  th, td{
			    padding:6px 4px;
			  }
			
			}
			
			</style>
			
			
			<div class='tableBox'>
			
			
			<!-- HEADER -->
			
			<div class='tableHeader'>
			
			<div class='tableTitle'>
			🏆 Top Nations by Decade
			</div>
			
			<div class='tableSub'>
			Leading countries ranked by medal performance within each Olympic decade
			</div>
			
			<div class='liveBadge'>LIVE</div>
			
			</div>
			
			
			<!-- TABLE -->
			
			<div class='scrollBox'>
			
			
			<table>
			
			
			<thead>
			
			<tr>
			  <th>Decade</th>
			  <th>#</th>
			  <th>Country</th>
			  <th>Total</th>
			  <th>Score</th>
			</tr>
			
			</thead>
			
			
			<tbody>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _Top,
			
			    VAR _Rank = [Rank]
			
			    VAR _Class =
			        IF(
			            _Rank = 1, "rank1",
			            IF(_Rank = 2, "rank2",
			            IF(_Rank = 3, "rank3",""))
			        )
			
			    RETURN
			
			
			"
			<tr class='" & _Class & "'>
			
			<td><b>" & calendar[Decade] & "</b></td>
			
			<td class='rankCol'>" & _Rank & "</td>
			
			<td class='countryCol'>" & results[Country] & "</td>
			
			<td>" & FORMAT([Total],"#,0") & "</td>
			
			<td class='scoreCol'>" & FORMAT([Score],"#,##0") & "</td>
			
			</tr>
			
			",
			
			"",
			
			calendar[Decade], ASC,
			[Rank], ASC
			
			)
			
			
			&
			
			
			"
			</tbody>
			
			
			</table>
			
			
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash 4
		lineageTag: 597fbf50-963b-42a8-a49a-fb9030d651d3

	measure 'Animated Era Transition HTML' = ```
			
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			
			SUMMARIZE(
			
			    results,
			
			    calendar[Decade],
			    results[Country],
			
			    "Score", [Medal Score]
			
			)
			
			
			
			/* =====================
			   RANK
			=====================*/
			
			VAR _Ranked =
			
			ADDCOLUMNS(
			
			    _Base,
			
			    "Rank",
			
			    VAR _Dec = calendar[Decade]
			
			    RETURN
			
			    RANKX(
			        FILTER(_Base, calendar[Decade] = _Dec),
			        [Score],
			        ,
			        DESC,
			        DENSE
			    )
			)
			
			
			
			/* =====================
			   TOP 3 PER DECADE
			=====================*/
			
			VAR _Top =
			
			FILTER(
			    _Ranked,
			    [Rank] <= 3
			)
			
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   ANIMATION FRAME
			=====================*/
			
			.animBox{
			  width:100%;
			  height:100%;
			
			  background:white;
			
			  border-radius:20px;
			  border:1px solid #e5e7eb;
			
			  padding:14px;
			
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  overflow:hidden;
			}
			
			
			/* Header */
			
			.animHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			  margin-bottom:10px;
			}
			
			.animTitle{
			  font-size:18px;
			  font-weight:900;
			  color:#111827;
			}
			
			.animSub{
			  font-size:11px;
			  color:#6b7280;
			}
			
			.liveBadge{
			  background:#dc2626;
			  color:white;
			
			  font-size:11px;
			  font-weight:800;
			
			  padding:3px 7px;
			  border-radius:5px;
			}
			
			
			/* Track */
			
			.track{
			  position:relative;
			  height:100%;
			  width:100%;
			  overflow:hidden;
			}
			
			
			/* Row */
			
			.row{
			  display:flex;
			  align-items:center;
			  gap:10px;
			
			  padding:8px 6px;
			
			  font-size:14px;
			
			  border-bottom:1px solid #f1f5f9;
			}
			
			
			/* Rank */
			
			.rank{
			  font-weight:900;
			  color:#dc2626;
			  width:24px;
			}
			
			
			/* Country */
			
			.country{
			  font-weight:800;
			  color:#111827;
			  width:160px;
			}
			
			
			/* Bar */
			
			.barWrap{
			  flex:1;
			  background:#f1f5f9;
			  height:10px;
			  border-radius:10px;
			  overflow:hidden;
			}
			
			.bar{
			  height:100%;
			  background:#dc2626;
			  animation:grow 2s ease-in-out infinite;
			}
			
			
			/* Decade Label */
			
			.decade{
			  font-size:11px;
			  font-weight:800;
			  color:#374151;
			  margin-bottom:6px;
			}
			
			
			/* =====================
			   ANIMATION
			=====================*/
			
			@keyframes grow{
			  0%{ width:0%; opacity:.3;}
			  40%{ opacity:1;}
			  100%{ width:100%;}
			}
			
			.slide{
			  animation:slide 15s linear infinite;
			}
			
			@keyframes slide{
			
			  0%{ transform:translateY(0);}
			  20%{ transform:translateY(0);}
			
			  25%{ transform:translateY(-25%);}
			  45%{ transform:translateY(-25%);}
			
			  50%{ transform:translateY(-50%);}
			  70%{ transform:translateY(-50%);}
			
			  75%{ transform:translateY(-75%);}
			  95%{ transform:translateY(-75%);}
			
			  100%{ transform:translateY(0);}
			}
			
			</style>
			
			
			<div class='animBox'>
			
			
			<!-- HEADER -->
			
			<div class='animHeader'>
			
			<div>
			
			<div class='animTitle'>
			📈 Era Transitions — Power Shifts
			</div>
			
			<div class='animSub'>
			Top 3 nations evolving across Olympic decades
			</div>
			
			</div>
			
			<div class='liveBadge'>LIVE</div>
			
			</div>
			
			
			<!-- TRACK -->
			
			<div class='track'>
			
			
			<div class='slide'>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _Top,
			
			    VAR _W = ROUND(DIVIDE([Score],MAXX(_Top,[Score]),0)*100,0)
			
			    RETURN
			
			
			"
			<div>
			
			<div class='decade'>" & calendar[Decade] & "s</div>
			
			
			<div class='row'>
			
			<div class='rank'>" & [Rank] & "</div>
			
			<div class='country'>" & results[Country] & "</div>
			
			<div class='barWrap'>
			<div class='bar' style='width:" & _W & "%'></div>
			</div>
			
			</div>
			
			</div>
			
			",
			
			"",
			
			calendar[Decade], ASC,
			[Rank], ASC
			
			)
			
			
			&
			
			
			"
			
			
			</div>
			
			</div>
			
			
			</div>
			"
			
			```
