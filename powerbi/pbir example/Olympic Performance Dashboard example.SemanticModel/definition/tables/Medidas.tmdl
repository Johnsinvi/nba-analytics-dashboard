	measure 'Line Chart Title' = ```
			
			
			VAR _Start = MIN(calendar[Year])
			VAR _End = MAX(calendar[Year])
			
			VAR _Growth =
			DIVIDE(
			    [Medal Score by Year] -
			    CALCULATE([Medal Score by Year], PREVIOUSYEAR(calendar[Date])),
			    CALCULATE([Medal Score by Year], PREVIOUSYEAR(calendar[Date]))
			)
			
			RETURN
			"📈 Olympic Medal Performance (" &
			_Start & "–" & _End &
			")"
			
			```
