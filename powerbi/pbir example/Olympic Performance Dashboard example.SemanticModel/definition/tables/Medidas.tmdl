	measure 'Athlete Tooltip Career v1' = ```
			
			
			
			/* =====================
			   SELECTED ATHLETE
			=====================*/
			
			VAR _Athlete =
			SELECTEDVALUE(athletes[Athlete])
			
			VAR _AthleteURL =
			SELECTEDVALUE(athletes[Athlete URL])
			
			VAR _Bio =
			SELECTEDVALUE(athletes[Bio])
			
			
			
			/* =====================
			   FORCE CONTEXT
			=====================*/
			
			VAR _AthleteFilter =
			TREATAS(
			    VALUES(athletes[Athlete URL]),
			    results[athlete_url]
			)
			
			
			
			/* =====================
			   GAMES LIST
			=====================*/
			
			VAR _GamesTable =
			SUMMARIZE(
			    CALCULATETABLE(
			        results,
			        _AthleteFilter
			    ),
			    results[Game Slug],
			    "GameName",
			        LOOKUPVALUE(
			            hosts[Game Name],
			            hosts[Game Slug],
			            results[Game Slug]
			        ),
			    "Year",
			        MAX(results[Game Year])
			)
			
			
			
			VAR _GamesHTML =
			CONCATENATEX(
			
			    _GamesTable,
			
			    "<li>" &
			    [GameName] & " (" & [Year] & ")" &
			    "</li>",
			
			    "",
			
			    [Year], ASC
			)
			
			
			
			/* =====================
			   BIO
			=====================*/
			
			VAR _BioFinal =
			IF(
			    NOT ISBLANK(_Bio),
			    _Bio,
			    "No biography available."
			)
			
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
