	measure 'Discipline Leaders HTML COMPACT' = ```
			
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			
			SUMMARIZE(
			
			    results,
			
			    results[Discipline],
			    results[Country],
			
			    "Score", [Medal Score],
			    "Total", [Total Medals]
			
			)
			
			
			
			/* =====================
			   RANK
			=====================*/
			
			VAR _Ranked =
			
			ADDCOLUMNS(
			
			    _Base,
			
			    "Rank",
			
			    VAR _Disc = results[Discipline]
			
			    RETURN
			
			    RANKX(
			        FILTER(_Base, results[Discipline] = _Disc),
			        [Score],
			        ,
			        DESC,
			        DENSE
			    )
			
			)
			
			
			
			/* =====================
			   TOTAL
			=====================*/
			
			VAR _WithTotal =
			
			ADDCOLUMNS(
			
			    _Ranked,
			
			    "DiscTotal",
			
			    VAR _D = results[Discipline]
			
			    RETURN
			
			    CALCULATE(
			        SUMX(
			            FILTER(_Ranked, results[Discipline] = _D),
			            [Score]
			        )
			    )
			
			)
			
			
			
			/* =====================
			   DOMINANCE
			=====================*/
			
			VAR _WithDom =
			
			ADDCOLUMNS(
			
			    _WithTotal,
			
			    "Dominance",
			
			    DIVIDE([Score],[DiscTotal],0)
			
			)
			
			
			
			/* =====================
			   TOP 3
			=====================*/
			
			VAR _Top =
			
			FILTER(
			    _WithDom,
			    [Rank] <= 3
			)
			
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   CONTAINER
			=====================*/
			
			.discBox{
			  width:100%;
			  height:100%;
			
			  background:white;
			
			  border-radius:18px;
			  border:1px solid #e5e7eb;
			
			  padding:10px 12px;
			
			  box-shadow:0 2px 6px rgba(0,0,0,.07);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  box-sizing:border-box;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.discHeader{
			  margin-bottom:6px;
			}
			
			.discTitle{
			  font-size:16px;
			  font-weight:900;
			  color:#111827;
			}
			
			.discSub{
			  font-size:10px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   SCROLL
			=====================*/
			
			.discScroll{
			  max-height:420px;
			  overflow-y:auto;
			
			  border-radius:12px;
			  border:1px solid #e5e7eb;
			}
			
			
			/* =====================
			   ROW
			=====================*/
			
			.discRow{
			  display:grid;
			
			  grid-template-columns:
			    36px
			    minmax(90px,1.8fr)
			    minmax(70px,1.4fr)
			    64px
			    1.6fr
			    46px;
			
			  align-items:center;
			
			  gap:4px;
			
			  padding:4px 6px;
			
			  font-size:11.5px;
			
			  border-bottom:1px solid #f1f5f9;
			
			  white-space:nowrap;
			}
			
			.discRow:hover{
			  background:#f9fafb;
			}
			
			
			/* =====================
			   COLUMNS
			=====================*/
			
			.discRank{
			  font-weight:900;
			  color:#dc2626;
			  text-align:center;
			}
			
			
			/* Discipline */
			
			.discName{
			  font-weight:800;
			  color:#111827;
			
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			
			/* Country */
			
			.discCountry{
			  font-weight:700;
			  color:#374151;
			
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			
			/* Score */
			
			.discScore{
			  font-weight:900;
			  color:#16a34a;
			  text-align:right;
			}
			
			
			/* =====================
			   BAR
			=====================*/
			
			.discBarWrap{
			  width:100%;
			  height:6px;
			
			  background:#f1f5f9;
			
			  border-radius:6px;
			
			  overflow:hidden;
			}
			
			.discBar{
			  height:100%;
			  background:#dc2626;
			}
			
			
			/* =====================
			   PERCENT
			=====================*/
			
			.discPct{
			  font-size:10px;
			  font-weight:800;
			  color:#dc2626;
			  text-align:right;
			}
			
			</style>
			
			
			<div class='discBox'>
			
			
			<!-- HEADER -->
			
			<div class='discHeader'>
			
			<div class='discTitle'>
			🏆 Discipline Leaders
			</div>
			
			<div class='discSub'>
			Top countries by medal dominance per discipline
			</div>
			
			</div>
			
			
			<!-- LIST -->
			
			<div class='discScroll'>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _Top,
			
			    VAR _Pct = ROUND([Dominance]*100,1)
			
			    RETURN
			
			
			"
			<div class='discRow'>
			
			<div class='discRank'>" & [Rank] & "</div>
			
			<div class='discName'>" & results[Discipline] & "</div>
			
			<div class='discCountry'>" & results[Country] & "</div>
			
			<div class='discScore'>" & FORMAT([Score],"#,##0") & "</div>
			
			<div class='discBarWrap'>
			  <div class='discBar' style='width:" & _Pct & "%'></div>
			</div>
			
			<div class='discPct'>" & FORMAT(_Pct,"0.0") & "%</div>
			
			</div>
			
			",
			
			"",
			
			results[Discipline], ASC,
			[Rank], ASC
			
			)
			
			
			&
			
			
			"
			
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash 5
		lineageTag: 8eab3db3-a763-415b-994d-7168c81872ed

	measure 'Discipline Evolution Line HTML FINAL' = ```
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			    SUMMARIZE(
			        results,
			        calendar[Year],
			        results[Discipline],
			        "Score", [Medal Score]
			    )
			
			
			/* =====================
			   TOP 5 DISCIPLINES
			=====================*/
			
			VAR _TopSports =
			    TOPN(
			        5,
			        VALUES(results[Discipline]),
			        CALCULATE([Medal Score]),
			        DESC
			    )
			
			
			/* =====================
			   FILTER BASE
			=====================*/
			
			VAR _Filtered =
			    FILTER(
			        _Base,
			        results[Discipline] IN _TopSports
			    )
			
			
			/* =====================
			   SCALE
			=====================*/
			
			VAR _MaxScore =
			    MAXX(_Filtered, [Score])
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			"
			<style>
			
			/* FRAME */
			
			.evoBox{
			  width:100%;
			  height:100%;
			  background:white;
			  border-radius:20px;
			  border:1px solid #e5e7eb;
			  padding:12px 14px;
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			  font-family:Segoe UI, Inter, Arial;
			  box-sizing:border-box;
			  display:flex;
			  flex-direction:column;
			}
			
			/* HEADER */
			
			.evoHeader{ margin-bottom:8px; }
			.evoTitle{ font-size:18px; font-weight:900; color:#111827; }
			.evoSub{ font-size:11px; color:#6b7280; }
			
			/* LEGEND */
			
			.evoLegend{
			  display:flex;
			  gap:10px;
			  flex-wrap:wrap;
			  margin-bottom:6px;
			}
			
			.legItem{
			  display:flex;
			  align-items:center;
			  gap:4px;
			  font-size:10px;
			  font-weight:700;
			  color:#374151;
			}
			
			.legDot{
			  width:10px;
			  height:10px;
			  border-radius:50%;
			}
			
			/* CHART */
			
			.chartWrap{
			  flex:1;
			  display:flex;
			  align-items:flex-end;
			  gap:2px;
			}
			
			/* BAR */
			
			.bar{
			  width:100%;
			  border-radius:4px 4px 0 0;
			  animation:grow 5s ease-in-out infinite;
			  transform-origin:bottom;
			}
			
			/* COLORS */
			
			.c1{ background:#dc2626; }
			.c2{ background:#2563eb; }
			.c3{ background:#16a34a; }
			.c4{ background:#9333ea; }
			.c5{ background:#f97316; }
			
			/* TOOLTIP */
			
			.bar:hover::after{
			  content:attr(data-disc) "" - "" attr(data-year) "" - "" attr(data-score);
			  position:absolute;
			  bottom:100%;
			  left:50%;
			  transform:translateX(-50%);
			  background:#111827;
			  color:white;
			  font-size:9px;
			  padding:3px 6px;
			  border-radius:4px;
			  white-space:nowrap;
			}
			
			/* ANIMATION */
			
			@keyframes grow{
			  0%{ transform:scaleY(.2); opacity:.4;}
			  30%{ transform:scaleY(1); opacity:1;}
			  80%{ transform:scaleY(1); opacity:1;}
			  100%{ transform:scaleY(.2); opacity:.4;}
			}
			
			</style>
			
			
			<div class='evoBox'>
			
			<div class='evoHeader'>
			  <div class='evoTitle'>📈 Discipline Evolution</div>
			  <div class='evoSub'>Medal performance trends across Olympic history (Top 5)</div>
			</div>
			
			
			<div class='chartWrap'>
			
			" &
			
			CONCATENATEX(
			    _Filtered,
			
			    VAR _Height =
			        ROUND(
			            DIVIDE([Score], _MaxScore, 0) * 100,
			            0
			        )
			
			    VAR _Rank =
			        RANKX(
			            _TopSports,
			            CALCULATE([Medal Score]),
			            ,
			            DESC,
			            DENSE
			        )
			
			    VAR _Color =
			        SWITCH(
			            _Rank,
			            1,"c1",
			            2,"c2",
			            3,"c3",
			            4,"c4",
			            "c5"
			        )
			
			    RETURN
			    "
			    <div class='bar " & _Color & "'
			         style='height:" & _Height & "%'
			         data-disc='" & results[Discipline] & "'
			         data-year='" & calendar[Year] & "'
			         data-score='" & FORMAT([Score], "#,##0") & "'>
			    </div>
			    ",
			
			    "",
			    calendar[Year], ASC,
			    results[Discipline], ASC
			)
			
			& "
			
			</div>
			</div>
			"
			
			```
		lineageTag: 1d71e894-fcf8-4c80-9313-5ef3e67f4dfe

	measure 'Discipline Story Cards HTML FINAL' = ```
			
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			SUMMARIZE(
			    results,
			    results[Discipline],
			    results[Country],
			    "Score", [Medal Score],
			    "Total", [Total Medals]
			)
			
			
			
			/* =====================
			   LEADERS PER DISCIPLINE
			=====================*/
			
			VAR _Leaders =
			ADDCOLUMNS(
			
			    SUMMARIZE(
			        results,
			        results[Discipline]
			    ),
			
			    /* Top Country */
			    "TopCountry",
			    CALCULATE(
			        SELECTEDVALUE(results[Country]),
			        TOPN(
			            1,
			            SUMMARIZE(
			                results,
			                results[Country],
			                "S", [Medal Score]
			            ),
			            [S],
			            DESC
			        )
			    ),
			
			    /* Top Score */
			    "TopScore",
			    CALCULATE(
			        MAXX(
			            SUMMARIZE(
			                results,
			                results[Country],
			                "S", [Medal Score]
			            ),
			            [S]
			        )
			    ),
			
			    /* Total Medals */
			    "TopTotal",
			    CALCULATE(
			        COUNTROWS('athlete medals')
			    ),
			
			    /* Peak Era */
			    "PeakEra",
			    CALCULATE(
			        SELECTEDVALUE(hosts[Era]),
			        TOPN(
			            1,
			            SUMMARIZE(
			                results,
			                hosts[Era],
			                "E", [Medal Score]
			            ),
			            [E],
			            DESC
			        )
			    )
			
			)
			
			
			
			/* =====================
			   LIMIT (TOP 8)
			=====================*/
			
			VAR _TopDisc =
			TOPN(
			    8,
			    _Leaders,
			    [TopScore],
			    DESC
			)
			
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   GRID
			=====================*/
			
			.storyGrid{
			  width:100%;
			  display:grid;
			  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
			  gap:12px;
			  font-family:Segoe UI, Inter, Arial;
			}
			
			
			/* =====================
			   CARD
			=====================*/
			
			.storyCard{
			  width:100%;
			  height:200px;
			  perspective:1000px;
			}
			
			
			/* INNER */
			
			.storyInner{
			  width:100%;
			  height:100%;
			  position:relative;
			  transition:transform .7s ease;
			  transform-style:preserve-3d;
			}
			
			.storyCard:hover .storyInner{
			  transform:rotateY(180deg);
			}
			
			
			/* =====================
			   FACES
			=====================*/
			
			.storyFront,
			.storyBack{
			  position:absolute;
			  width:100%;
			  height:100%;
			  backface-visibility:hidden;
			  border-radius:18px;
			  border:1px solid #e5e7eb;
			  background:white;
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			  padding:12px;
			  box-sizing:border-box;
			  display:flex;
			  flex-direction:column;
			  justify-content:space-between;
			}
			
			
			/* BACK */
			
			.storyBack{
			  transform:rotateY(180deg);
			  background:#f8fafc;
			}
			
			
			/* =====================
			   FRONT
			=====================*/
			
			.storyTitle{
			  font-size:14px;
			  font-weight:900;
			  color:#111827;
			  border-bottom:2px solid #dc2626;
			  padding-bottom:4px;
			}
			
			.storyCountry{
			  font-size:12px;
			  font-weight:800;
			  color:#374151;
			}
			
			.storyScore{
			  font-size:20px;
			  font-weight:900;
			  color:#16a34a;
			}
			
			.storySub{
			  font-size:10px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   BACK
			=====================*/
			
			.storyText{
			  font-size:11px;
			  color:#374151;
			  line-height:1.4;
			}
			
			.storyEra{
			  font-size:11px;
			  font-weight:800;
			  color:#dc2626;
			}
			
			</style>
			
			
			
			<div class='storyGrid'>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _TopDisc,
			
			    VAR _Story =
			        "In " &
			        results[Discipline] &
			        ", " &
			        [TopCountry] &
			        " established historical dominance with consistent medal performance, peaking during the " &
			        [PeakEra] &
			        " era."
			
			    RETURN
			
			
			"
			<div class='storyCard'>
			
			<div class='storyInner'>
			
			
			<!-- FRONT -->
			
			<div class='storyFront'>
			
			<div class='storyTitle'>
			" & results[Discipline] & "
			</div>
			
			<div class='storyCountry'>
			🏆 " & [TopCountry] & "
			</div>
			
			<div class='storyScore'>
			" & FORMAT([TopScore],"#,##0") & "
			</div>
			
			<div class='storySub'>
			Total Medals: " & FORMAT([TopTotal],"#,0") & "
			</div>
			
			</div>
			
			
			<!-- BACK -->
			
			<div class='storyBack'>
			
			<div class='storyText'>
			" & _Story & "
			</div>
			
			<div class='storyEra'>
			Peak Era: " & [PeakEra] & "
			</div>
			
			</div>
			
			
			</div>
			
			</div>
			
			",
			
			""
			
			)
			
			
			&
			
			
			"
			
			</div>
			"
			
			```
