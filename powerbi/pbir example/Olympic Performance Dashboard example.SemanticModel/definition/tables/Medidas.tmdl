			.cardValue{
			  font-size:17px;
			  font-weight:900;
			  color:#111827;
			
			  margin:2px 0;
			
			  white-space:nowrap;
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			.cardSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   BACK
			=====================*/
			
			.backIcon{
			  font-size:14px;
			  margin-bottom:3px;
			}
			
			.backText{
			  font-size:9px;
			  color:#374151;
			  line-height:1.25;
			
			  text-align:center;
			}
			
			</style>
			
			
			<div class='masterBox'>
			
			
			<!-- HEADER -->
			<div class='pageHeader'>
			
			<div class='mainTitle'>
			🏅 Athletes & Legends
			<span class='badgeLive'>LIVE</span>
			</div>
			
			
			<div class='countWrap'>
			
			
			<!-- WINTER -->
			
			<div class='countBox'>
			
			<div class='countTitle'>Winter Medals</div>
			
			<div class='countTime'>" & _FmtWinter & "</div>
			
			<div class='countSub'>Current Selection</div>
			
			</div>
			
			
			<!-- SUMMER -->
			
			<div class='countBox'>
			
			<div class='countTitle'>Summer Medals</div>
			
			<div class='countTime'>" & _FmtSummer & "</div>
			
			<div class='countSub'>Current Selection</div>
			
			</div>
			
			
			</div>
			
			</div>
			
			
			<!-- GRID -->
			<div class='flipGrid'>
			
			
			<!-- SCORE -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='face front'>
			
			<div class='cardTitle'>Medal Score</div>
			<div class='cardValue'>" & _FmtScore & "</div>
			<div class='cardSub'>Weighted Index</div>
			
			</div>
			
			<div class='face back'>
			
			<div class='backIcon'>🏆</div>
			
			<div class='backText'>
			Overall performance score weighted by medal type.
			</div>
			
			</div>
			
			</div></div>
			
			
			<!-- AVG -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='face front'>
			
			<div class='cardTitle'>Avg Career</div>
			<div class='cardValue'>" & _FmtAvg & "</div>
			<div class='cardSub'>Games / Athlete</div>
			
			</div>
			
			<div class='face back'>
			
			<div class='backIcon'>📊</div>
			
			<div class='backText'>
			Average Olympic participations.
			</div>
			
			</div>
			
			</div></div>
			
			
			<!-- ATHLETES -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='face front'>
			
			<div class='cardTitle'>Athletes</div>
			<div class='cardValue'>" & _FmtAth & "</div>
			<div class='cardSub'>In Selection</div>
			
			</div>
			
			<div class='face back'>
			
			<div class='backIcon'>🏃‍♂️</div>
			
			<div class='backText'>
			Distinct athletes filtered.
			</div>
			
			</div>
			
			</div></div>
			
			
			<!-- MULTI -->
			<div class='flipCard'><div class='flipInner'>
			
			<div class='face front'>
			
			<div class='cardTitle'>Multi-Medalists</div>
			<div class='cardValue'>" & _FmtMulti & "</div>
			<div class='cardSub'>5+ Medals</div>
			
			</div>
			
			<div class='face back'>
			
			<div class='backIcon'>🥇</div>
			
			<div class='backText'>
			Athletes with 5+ medals.
			</div>
			
			</div>
			
			</div></div>
			
			
			</div>
			
			</div>
			"
			
