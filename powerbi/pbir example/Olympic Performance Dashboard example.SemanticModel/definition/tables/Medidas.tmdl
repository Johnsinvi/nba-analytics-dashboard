	measure 'Legacy Timeline Animated HTML FINAL' = ```
			
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			
			SUMMARIZE(
			
			    calendar,
			
			    calendar[Year],
			
			    "Score",
			        CALCULATE( [Medal Score] )
			
			)
			
			
			
			/* =====================
			   FILTER VALID
			=====================*/
			
			VAR _Valid =
			
			FILTER(
			    _Base,
			    NOT ISBLANK([Score])
			)
			
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   TIMELINE FRAME
			=====================*/
			
			.timelineBox{
			  width:100%;
			  height:100%;
			
			  background:white;
			
			  border-radius:20px;
			  border:1px solid #e5e7eb;
			
			  padding:14px;
			
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  box-sizing:border-box;
			
			  overflow:hidden;
			}
			
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.timeHeader{
			  margin-bottom:10px;
			}
			
			.timeTitle{
			  font-size:18px;
			  font-weight:900;
			  color:#111827;
			}
			
			.timeSub{
			  font-size:11px;
			  color:#6b7280;
			}
			
			
			
			/* =====================
			   CHART
			=====================*/
			
			.chartWrap{
			  position:relative;
			  width:100%;
			  height:calc(100% - 50px);
			
			  display:flex;
			  align-items:flex-end;
			  gap:4px;
			}
			
			
			/* Bar */
			
			.bar{
			  flex:1;
			
			  background:linear-gradient(
			    to top,
			    #dc2626,
			    #f87171
			  );
			
			  border-radius:6px 6px 0 0;
			
			  animation:grow 6s ease-in-out infinite;
			
			  transform-origin:bottom;
			}
			
			
			
			/* Tooltip */
			
			.bar::after{
			  content:attr(data-year) " - " attr(data-score);
			
			  position:absolute;
			
			  bottom:100%;
			  left:50%;
			
			  transform:translateX(-50%);
			
			  background:#111827;
			
			  color:white;
			
			  font-size:9px;
			
			  padding:2px 5px;
			
			  border-radius:4px;
			
			  opacity:0;
			
			  pointer-events:none;
			
			  transition:.3s;
			}
			
			.bar:hover::after{
			  opacity:1;
			}
			
			
			
			/* =====================
			   ANIMATION
			=====================*/
			
			@keyframes grow{
			
			  0%{
			    transform:scaleY(.1);
			    opacity:.4;
			  }
			
			  30%{
			    transform:scaleY(1);
			    opacity:1;
			  }
			
			  80%{
			    transform:scaleY(1);
			    opacity:1;
			  }
			
			  100%{
			    transform:scaleY(.1);
			    opacity:.4;
			  }
			
			}
			
			</style>
			
			
			<div class='timelineBox'>
			
			
			<!-- HEADER -->
			
			<div class='timeHeader'>
			
			<div class='timeTitle'>
			📈 Olympic Legacy Timeline
			</div>
			
			<div class='timeSub'>
			Evolution of medal performance across Olympic history
			</div>
			
			</div>
			
			
			<!-- CHART -->
			
			<div class='chartWrap'>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _Valid,
			
			    VAR _Max = MAXX(_Valid,[Score])
			
			    VAR _H = ROUND( DIVIDE([Score],_Max,0) * 100 ,0)
			
			    RETURN
			
			
			"
			<div class='bar'
			     style='height:" & _H & "%'
			     data-year='" & calendar[Year] & "'
			     data-score='" & FORMAT([Score],"#,##0") & "'>
			</div>
			",
			
			"",
			
			calendar[Year], ASC
			
			)
			
			
			&
			
			
			"
			
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash ext
		lineageTag: d0981320-c778-4043-9344-91102e566abf

	measure 'Olympic Sports Header Page 5 FINAL v2' = ```
			
			
			
			/* =====================
			   CORE METRICS
			=====================*/
			
			-- Top Sport (Most Medals)
			
			VAR _TopSport =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(1,ALL(results[Discipline]),[Total Medals],DESC)
			)
			
			VAR _TopSportMedals =
			CALCULATE(
			    [Total Medals],
			    results[Discipline] = _TopSport
			)
			
			
			
			-- Highest Score Sport
			
			VAR _PeakSport =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(1,ALL(results[Discipline]),[Medal Score],DESC)
			)
			
			VAR _PeakScore =
			CALCULATE(
			    [Medal Score],
			    results[Discipline] = _PeakSport
			)
			
			
			
			-- Top Nation in Top Sport
			
			VAR _TopNationSport =
			CALCULATE(
			    SELECTEDVALUE(results[Country]),
			    TOPN(
			        1,
			        FILTER(
			            ALL(results),
			            results[Discipline] = _TopSport
			        ),
			        [Medal Score],
			        DESC
			    )
			)
			
			
			
			-- Rising Sport (Growth after 2000)
			
			VAR _RisingSport =
			
			TOPN(
			    1,
			
			    ADDCOLUMNS(
			
			        VALUES(results[Discipline]),
			
			        "Growth",
			
			        CALCULATE(
			            [Medal Score],
			            calendar[Year] >= 2000
			        )
			
			        -
			        CALCULATE(
			            [Medal Score],
			            calendar[Year] < 2000
			        )
			    ),
			
			    [Growth],
			    DESC
			)
			
			
			VAR _RisingName =
			MAXX(_RisingSport, results[Discipline])
			
			
			
			/* =====================
			   WINTER / SUMMER
			=====================*/
			
			VAR _WinterSports =
			CALCULATE(
			    DISTINCTCOUNT(results[Discipline]),
			    hosts[Season] = "Winter"
			)
			
			VAR _SummerSports =
			CALCULATE(
			    DISTINCTCOUNT(results[Discipline]),
			    hosts[Season] = "Summer"
			)
			
			
			VAR _FmtWinter = FORMAT(_WinterSports,"#,0")
			VAR _FmtSummer = FORMAT(_SummerSports,"#,0")
			
			
			
			/* =====================
			   FORMAT
			=====================*/
			
			VAR _FmtTopMedals = FORMAT(_TopSportMedals,"#,##0")
			VAR _FmtPeak = FORMAT(_PeakScore,"#,##0")
			
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   MASTER (PADRÃO GLOBAL)
			=====================*/
			
			.sportBox{
			  width:100%;
			  background:#ffffff;
			
			  border-radius:16px;
			  border:1px solid #e5e7eb;
			
			  padding:10px 12px;
			
			  box-shadow:0 2px 6px rgba(0,0,0,.07);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  box-sizing:border-box;
			}
			
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.pageHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			
			  gap:8px;
			  margin-bottom:8px;
			
			  flex-wrap:wrap;
			}
			
			
			.headerLeft{
			  display:flex;
			  flex-direction:column;
			}
			
			
			.mainTitle{
			  font-size:17px;        /* PADRÃO */
			  font-weight:900;
			  color:#111827;
			
			  display:flex;
			  align-items:center;
			  gap:6px;
			}
			
			
			.badgeLive{
			  background:#dc2626;
			  color:white;
			
			  font-size:9px;
			  font-weight:800;
			
			  padding:2px 5px;
			  border-radius:4px;
			}
			
			
			.subTitle{
			  font-size:9px;
			  color:#6b7280;
			  margin-top:1px;
			}
			
			
			
			/* =====================
			   SEASON BOX
			=====================*/
			
			.seasonWrap{
			  display:flex;
			  gap:10px;
			}
			
			
			.seasonBox{
			  text-align:right;
			  min-width:100px;
			}
			
			
			.seasonTitle{
			  font-size:8px;
			  font-weight:700;
			  color:#dc2626;
			  text-transform:uppercase;
			}
			
			
			.seasonValue{
			  font-size:12px;
			  font-weight:900;
			  color:#111827;
			}
			
			
			.seasonSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			
			/* =====================
			   GRID
			=====================*/
			
			.flipGrid{
			  display:grid;
			
			  grid-template-columns:
			  repeat(auto-fit,minmax(120px,1fr));
			
			  gap:7px;
			}
			
			
			
			/* =====================
			   CARD
			=====================*/
			
			.flipCard{
			  width:100%;
			  height:73px;      /* PADRÃO GLOBAL */
			  perspective:1000px;
			}
			
			
			.flipInner{
			  width:100%;
			  height:100%;
			
			  position:relative;
			
			  transition:transform .6s ease;
			  transform-style:preserve-3d;
			}
			
			
			.flipCard:hover .flipInner{
			  transform:rotateY(180deg);
			}
			
			
			
			/* =====================
			   FACES
			=====================*/
			
			.flipFront,
			.flipBack{
			  position:absolute;
			
			  width:100%;
			  height:100%;
			
			  backface-visibility:hidden;
			
			  border-radius:10px;
			
			  border:1px solid #e5e7eb;
			  background:white;
			
			  box-shadow:0 2px 5px rgba(0,0,0,.07);
			
			  padding:6px;
			
			  box-sizing:border-box;
			
			  display:flex;
			  flex-direction:column;
			  justify-content:center;
			  align-items:center;
			
			  text-align:center;
			}
			
			
			.flipBack{
			  transform:rotateY(180deg);
			  background:#f8fafc;
			}
			
			
			
			/* =====================
			   CARD HEADER
			=====================*/
			
			.cardHeader{
			  width:100%;
			
			  font-size:10px;
			  font-weight:900;
			
			  color:#dc2626;
			  text-transform:uppercase;
			
			  border-bottom:2px solid #dc2626;
			
			  padding-bottom:2px;
			  margin-bottom:3px;
			}
			
			
			
			/* =====================
			   VALUE
			=====================*/
			
			.cardValue{
			  font-size:17px;
			  font-weight:900;
			  color:#111827;
			
			  white-space:nowrap;
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			
			.cardSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			
			/* =====================
			   BACK
			=====================*/
			
			.backIcon{
			  font-size:14px;
			  margin-bottom:3px;
			}
			
			.backText{
			  font-size:9px;
			  color:#374151;
			  line-height:1.25;
			}
			
			</style>
			
			
			<div class='sportBox'>
			
			
			<!-- HEADER -->
			
			<div class='pageHeader'>
			
			
			<!-- LEFT -->
			
			<div class='headerLeft'>
			
			
			<div class='mainTitle'>
			🏟️ Sports & Disciplines Intelligence
			<span class='badgeLive'>LIVE</span>
			</div>
			
			
			<div class='subTitle'>
			Performance • Dominance • Evolution
			</div>
			
			
			</div>
			
			
			
			<!-- RIGHT -->
			
			<div class='seasonWrap'>
			
			
			<div class='seasonBox'>
			
			<div class='seasonTitle'>Winter Sports</div>
			<div class='seasonValue'>" & _FmtWinter & "</div>
			<div class='seasonSub'>Disciplines</div>
			
			</div>
			
			
			<div class='seasonBox'>
			
			<div class='seasonTitle'>Summer Sports</div>
			<div class='seasonValue'>" & _FmtSummer & "</div>
			<div class='seasonSub'>Disciplines</div>
			
			</div>
			
			
			</div>
			
			
			</div>
			
			
			
			<!-- KPI GRID -->
			
			<div class='flipGrid'>
			
			
			<!-- TOP SPORT -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Top Sport</div>
			
			<div class='cardValue'>" & _TopSport & "</div>
			
			<div class='cardSub'>" & _FmtTopMedals & " medals</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🥇</div>
			
			<div class='backText'>
			Discipline with the highest number of medals.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			<!-- PEAK SCORE -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Peak Score</div>
			
			<div class='cardValue'>" & _PeakSport & "</div>
			
			<div class='cardSub'>" & _FmtPeak & " pts</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🔥</div>
			
			<div class='backText'>
			Sport with highest cumulative score.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			<!-- TOP NATION -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Top Nation</div>
			
			<div class='cardValue'>" & _TopNationSport & "</div>
			
			<div class='cardSub'>In " & _TopSport & "</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🌍</div>
			
			<div class='backText'>
			Strongest dominance in discipline.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			<!-- RISING SPORT -->
			
			<div class='flipCard'><div class='flipInner'>
			
			
			<div class='flipFront'>
			
			<div class='cardHeader'>Rising Sport</div>
			
			<div class='cardValue'>" & _RisingName & "</div>
			
			<div class='cardSub'>Post-2000 growth</div>
			
			</div>
			
			
			<div class='flipBack'>
			
			<div class='backIcon'>🚀</div>
			
			<div class='backText'>
			Fastest growing discipline.
			</div>
			
			</div>
			
			
			</div></div>
			
			
			
			</div>
			
			
			</div>
			"
			
			```
