	measure 'Olympic Athlete Medal Table SAFE' = ```
			
			
			
			/* =========================
			   BASE
			========================= */
			
			VAR _BaseTable =
			SUMMARIZE(
			    athletes,
			    athletes[Athlete],
			
			    "Gold",
			        CALCULATE(
			            COUNTROWS('athlete medals'),
			            'athlete medals'[Medal] = "Gold"
			        ),
			
			    "Silver",
			        CALCULATE(
			            COUNTROWS('athlete medals'),
			            'athlete medals'[Medal] = "Silver"
			        ),
			
			    "Bronze",
			        CALCULATE(
			            COUNTROWS('athlete medals'),
			            'athlete medals'[Medal] = "Bronze"
			        ),
			
			    "Total",
			        COUNTROWS('athlete medals'),
			
			    "Score",
			        SUM(results[Medal Value])
			)
			
			
			
			/* =========================
			   RANK
			========================= */
			
			VAR _Ranked =
			ADDCOLUMNS(
			    _BaseTable,
			
			    "Rank",
			    RANKX(
			        _BaseTable,
			        [Score],
			        ,
			        DESC,
			        DENSE
			    )
			)
			
			
			
			/* =========================
			   TOP 50
			========================= */
			
			VAR _Top =
			TOPN(
			    50,
			    _Ranked,
			    [Score], DESC
			)
			
			
			
			/* =========================
			   HTML
			========================= */
			
			RETURN
			
			
			"
			<style>
			.t{background:#f8fafc;border-radius:16px;padding:12px;border:1px solid #e5e7eb;font-family:Segoe UI}
			.h{font-size:18px;font-weight:900;color:#111827;margin-bottom:8px;display:flex;justify-content:space-between}
			.b{background:#dc2626;color:#fff;font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px}
			.s{max-height:420px;overflow-y:auto;border-radius:10px;border:1px solid #e5e7eb;background:#fff}
			table{width:100%;border-collapse:collapse;font-size:12px}
			th{background:#f1f5f9;position:sticky;top:0;padding:6px;font-weight:700;color:#374151;border-bottom:1px solid #e5e7eb}
			td{padding:6px;border-bottom:1px solid #f1f5f9}
			tr:hover{background:#f9fafb}
			.r1{background:rgba(250,204,21,.15)}
			.r2{background:rgba(209,213,219,.18)}
			.r3{background:rgba(192,132,252,.15)}
			.r{font-weight:800;color:#dc2626;width:28px}
			.a{font-weight:700;white-space:nowrap}
			.sc{font-weight:800;color:#16a34a}
			</style>
			
			
			<div class='t'>
			
			
			<div class='h'>
			<div>🏅 Athlete Ranking</div>
			<div class='b'>LIVE</div>
			</div>
			
			
			<div class='s'>
			
			
			<table>
			
			<thead>
			<tr>
			<th>#</th>
			<th>Athlete</th>
			<th>🥇</th>
			<th>🥈</th>
			<th>🥉</th>
			<th>Total</th>
			<th>Score</th>
			</tr>
			</thead>
			
			
			<tbody>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _Top,
			
			    VAR k = [Rank]
			
			    VAR c =
			        IF(
			            k = 1,"r1",
			            IF(k = 2,"r2",
			            IF(k = 3,"r3",""))
			        )
			
			    RETURN
			
			
			"
			<tr class='" & c & "'>
			
			<td class='r'>" & k & "</td>
			
			<td class='a'>" & [Athlete] & "</td>
			
			<td>" & [Gold] & "</td>
			<td>" & [Silver] & "</td>
			<td>" & [Bronze] & "</td>
			
			<td><b>" & [Total] & "</b></td>
			
			<td class='sc'>" &
			FORMAT([Score],"#,##0") &
			"</td>
			
			</tr>
			
			",
			
			"",
			
			[Rank],ASC
			
			)
			
			
			&
			
			
			"
			
			</tbody>
			
			</table>
			
			
			</div>
			
			</div>
			"
			
			```
		displayFolder: Dash 3
		lineageTag: d04e357e-9660-4ce1-890a-19ce45705fc3

