	measure 'Olympic Evolution Header Page 4 FINAL v3' = ```
			
			
			
			/* =====================
			   METRICS
			=====================*/
			
			VAR _TopNationEra =
			CALCULATE(
			    SELECTEDVALUE(results[Country]),
			    TOPN(1,ALL(results[Country]),[Medal Score],DESC)
			)
			
			
			VAR _TopNationScore =
			CALCULATE(
			    [Medal Score],
			    results[Country] = _TopNationEra
			)
			
			
			VAR _PeakEdition =
			CALCULATE(
			    SELECTEDVALUE(hosts[Game Name]),
			    TOPN(
			        1,
			        VALUES(results[Game Slug]),
			        [Medal Score],
			        DESC
			    )
			)
			
			
			VAR _PeakScore =
			MAXX(
			    VALUES(results[Game Slug]),
			    [Medal Score]
			)
			
			
			VAR _BestDecade =
			CALCULATE(
			    SELECTEDVALUE(calendar[Decade]),
			    TOPN(1,ALL(calendar[Decade]),[Medal Score],DESC)
			)
			
			
			VAR _NewPowers =
			CALCULATE(
			    DISTINCTCOUNT(results[Country]),
			    results[Game Year] >= 1990
			)
			
			
			
			/* =====================
			   WINTER / SUMMER
			=====================*/
			
			VAR _WinterScore =
			CALCULATE(
			    [Medal Score],
			    hosts[Season] = "Winter"
			)
			
			VAR _SummerScore =
			CALCULATE(
			    [Medal Score],
			    hosts[Season] = "Summer"
			)
			
			
			
			/* =====================
			   FORMAT
			=====================*/
			
			VAR _FmtTopScore   = FORMAT(_TopNationScore,"#,##0")
			VAR _FmtPeakScore  = FORMAT(_PeakScore,"#,##0")
			VAR _FmtWinter     = FORMAT(_WinterScore,"#,##0")
			VAR _FmtSummer     = FORMAT(_SummerScore,"#,##0")
			VAR _FmtNewPowers  = FORMAT(_NewPowers,"#,0")
			
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   PAGE BOX
			=====================*/
			
			.pageBox{
			  width:100%;
			  background:#ffffff;
			  border-radius:16px;
			  border:1px solid #e5e7eb;
			
			  padding:10px 12px;
			
			  box-shadow:0 2px 6px rgba(0,0,0,.07);
			
			  font-family:Segoe UI, Inter, Arial;
			  box-sizing:border-box;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.pageHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			
			  margin-bottom:8px;
			
			  flex-wrap:wrap;
			  gap:8px;
			}
			
			.headerLeft{
			  display:flex;
			  flex-direction:column;
			}
			
			.mainTitle{
			  font-size:17px;
			  font-weight:900;
			  color:#111827;
			
			  display:flex;
			  align-items:center;
			  gap:6px;
			}
			
			.liveBadge{
			  background:#dc2626;
			  color:white;
			
			  font-size:9px;
			  font-weight:800;
			
			  padding:2px 5px;
			  border-radius:4px;
			}
			
			.subTitle{
			  font-size:9px;
			  color:#6b7280;
			  margin-top:1px;
			}
			
			
			/* =====================
			   RIGHT INFO
			=====================*/
			
			.headerRight{
			  display:flex;
			  gap:10px;
			}
			
			.seasonBox{
			  text-align:right;
			  min-width:100px;
			}
			
			.seasonTitle{
			  font-size:8px;
			  font-weight:700;
			  color:#dc2626;
			  text-transform:uppercase;
			}
			
			.seasonVal{
			  font-size:12px;
			  font-weight:900;
			  color:#111827;
			}
			
			.seasonSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   GRID
			=====================*/
			
			.kpiGrid{
			  display:grid;
			  grid-template-columns:repeat(auto-fit,minmax(120px,1fr));
			  gap:7px;
			}
			
			
			/* =====================
			   FLIP CARD
			=====================*/
			
			.flipCard{
			  height:73px;
			  perspective:1000px;
			}
			
			.flipInner{
			  width:100%;
			  height:100%;
			  position:relative;
			  transition:transform .6s ease;
			  transform-style:preserve-3d;
			}
			
			.flipCard:hover .flipInner{
			  transform:rotateY(180deg);
			}
			
			
			/* =====================
			   FACES
			=====================*/
			
			.flipFront,
			.flipBack{
			  position:absolute;
			  width:100%;
			  height:100%;
			
			  backface-visibility:hidden;
			
			  border-radius:10px;
			  border:1px solid #e5e7eb;
			  background:white;
			
			  box-shadow:0 2px 5px rgba(0,0,0,.07);
			
			  padding:6px;
			
			  display:flex;
			  flex-direction:column;
			  align-items:center;
			  justify-content:center;
			
			  text-align:center;
			}
			
			.flipBack{
			  transform:rotateY(180deg);
			  background:#f8fafc;
			}
			
			
			/* =====================
			   KPI TITLE
			=====================*/
			
			.kpiTitle{
			  width:100%;
			  text-align:center;
			
			  font-size:10px;
			  font-weight:900;
			  color:#dc2626;
			
			  text-transform:uppercase;
			
			  border-bottom:2px solid #dc2626;
			
			  padding-bottom:2px;
			  margin-bottom:3px;
			}
			
			
			/* =====================
			   VALUES
			=====================*/
			
			.kpiValue{
			  font-size:17px;     /* PADRÃO GLOBAL */
			  font-weight:900;
			  color:#111827;
			
			  white-space:nowrap;
			  overflow:hidden;
			  text-overflow:ellipsis;
			
			  max-width:100%;
			}
			
			.kpiSub{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* =====================
			   BACK
			=====================*/
			
			.backIcon{
			  font-size:14px;
			  margin-bottom:3px;
			}
			
			.backText{
			  font-size:9px;
			  color:#374151;
			  line-height:1.25;
			}
			
			</style>
			
			
			<div class='pageBox'>
			
			
			<!-- HEADER -->
			
			<div class='pageHeader'>
			
			
			<!-- LEFT -->
			
			<div class='headerLeft'>
			
			<div class='mainTitle'>
			📊 Olympic Evolution & Dynasties
			<span class='liveBadge'>LIVE</span>
			</div>
			
			<div class='subTitle'>
			Power Shifts • Dominance • Eras • 1896–2022
			</div>
			
			</div>
			
			
			<!-- RIGHT -->
			
			<div class='headerRight'>
			
			
			<div class='seasonBox'>
			<div class='seasonTitle'>Winter Sports</div>
			<div class='seasonVal'>" & _FmtWinter & "</div>
			<div class='seasonSub'>Score</div>
			</div>
			
			
			<div class='seasonBox'>
			<div class='seasonTitle'>Summer Sports</div>
			<div class='seasonVal'>" & _FmtSummer & "</div>
			<div class='seasonSub'>Score</div>
			</div>
			
			
			</div>
			
			</div>
			
			
			<!-- KPI GRID -->
			
			<div class='kpiGrid'>
			
			
			<!-- ERA LEADER -->
			
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='kpiTitle'>Era Leader</div>
			<div class='kpiValue'>" & _TopNationEra & "</div>
			<div class='kpiSub'>Score " & _FmtTopScore & "</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>🏆</div>
			<div class='backText'>
			Country with the highest cumulative medal score.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- PEAK EDITION -->
			
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='kpiTitle'>Peak Edition</div>
			
			<!-- TAMANHO PADRONIZADO -->
			<div class='kpiValue'>" & _PeakEdition & "</div>
			
			<div class='kpiSub'>" & _FmtPeakScore & " Score</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>🔥</div>
			<div class='backText'>
			Highest single-edition performance.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- GOLDEN AGE -->
			
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='kpiTitle'>Golden Age</div>
			<div class='kpiValue'>" & _BestDecade & "</div>
			<div class='kpiSub'>Top Decade</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>⏳</div>
			<div class='backText'>
			Peak decade of elite performance.
			</div>
			</div>
			
			</div></div>
			
			
			<!-- NEW POWERS -->
			
			<div class='flipCard'><div class='flipInner'>
			
			<div class='flipFront'>
			<div class='kpiTitle'>New Powers</div>
			<div class='kpiValue'>" & _FmtNewPowers & "</div>
			<div class='kpiSub'>Post-1990</div>
			</div>
			
			<div class='flipBack'>
			<div class='backIcon'>🚀</div>
			<div class='backText'>
			Emerging Olympic nations.
			</div>
			</div>
			
			</div></div>
			
			
			</div>
			
			
			</div>
			"
			
			```
		displayFolder: Dash 4
