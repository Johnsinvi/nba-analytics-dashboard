	measure 'Olympic Athletes Header ESPN Flip FINAL v9' = ```
			
			
			
			/* =====================
			   ATHLETE CONTEXT
			=====================*/
			
			VAR _AthleteFilter =
			TREATAS(
			    VALUES(athletes[Athlete URL]),
			    'results'[athlete_url]
			)
			
			
			/* =====================
			   CORE METRICS
			=====================*/
			
			VAR _Score =
			CALCULATE(
			    [Medal Score],
			    _AthleteFilter
			)
			
			VAR _AvgCareer =
			CALCULATE(
			    AVERAGEX(
			        VALUES(athletes[Athlete]),
			        DISTINCTCOUNT(results[Game Slug])
			    ),
			    _AthleteFilter
			)
			
			VAR _TotalAthletes =
			CALCULATE(
			    DISTINCTCOUNT(athletes[Athlete]),
			    _AthleteFilter
			)
			
			VAR _Multi =
			CALCULATE(
			    [Multi Medalists],
			    _AthleteFilter
			)
			
			
			/* =====================
			   TOP MEDALS
			=====================*/
			
			VAR _WinterMedals =
			CALCULATE(
			    [Total Medals],
			    hosts[Season] = "Winter"
			)
			
			VAR _SummerMedals =
			CALCULATE(
			    [Total Medals],
			    hosts[Season] = "Summer"
			)
			
			
			/* =====================
			   FORMAT
			=====================*/
			
			VAR _FmtScore = FORMAT(_Score,"#,##0")
			VAR _FmtAth = FORMAT(_TotalAthletes,"#,##0")
			VAR _FmtMulti = FORMAT(_Multi,"#,##0")
			VAR _FmtAvg = FORMAT(_AvgCareer,"0.0")
			
			VAR _FmtWinter = FORMAT(_WinterMedals,"#,##0")
			VAR _FmtSummer = FORMAT(_SummerMedals,"#,##0")
			
			
			RETURN
			
			
