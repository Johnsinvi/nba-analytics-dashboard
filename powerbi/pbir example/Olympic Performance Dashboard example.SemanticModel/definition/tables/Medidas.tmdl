	measure 'Olympic Athlete Rank Flip Carousel' = ```
			
			
			VAR _Base =
			
			ADDCOLUMNS(
			
			    SUMMARIZE(
			        results,
			        results[athlete_full_name]
			    ),
			
			    /* Medals */
			    "Medals",
			    CALCULATE([Total Medals]),
			
			    /* Score */
			    "Score",
			    CALCULATE([Medal Score]),
			
			    /* Country */
			    "Country",
			    CALCULATE(SELECTEDVALUE(results[NOC])),
			
			    /* Main Sport */
			    "Sport",
			    CALCULATE(
			        SELECTEDVALUE(results[Discipline]),
			        TOPN(
			            1,
			            SUMMARIZE(
			                results,
			                results[Discipline],
			                "S", SUM(results[Medal Value])
			            ),
			            [S],
			            DESC
			        )
			    ),
			
			    /* Last Year */
			    "MaxYear",
			    MAX(hosts[Year]),
			
			    /* URL */
			    "URL",
			    CALCULATE(SELECTEDVALUE(results[athlete_url]))
			)
			
			
			VAR _Top =
			
			TOPN(
			    15,
			    _Base,
			    [Score],
			    DESC
			)
			
			
			VAR _Cards =
			
			CONCATENATEX(
			
			    _Top,
			
			    VAR _Name = [athlete_full_name]
			    VAR _Medals = [Medals]
			    VAR _Score = [Score]
			    VAR _Country = [Country]
			    VAR _Sport = [Sport]
			    VAR _Year = [MaxYear]
			    VAR _URL = [URL]
			
			    VAR _FinalURL =
			        IF(
			            LEFT(_URL,1)="/",
			            "https://www.olympics.com" & _URL,
			            _URL
			        )
			
			    RETURN
			
			"
			<div class='flipCard'
			     onclick=""window.open('" & _FinalURL & "','_blank')"">
			
			<div class='flipInner'>
			
			
			<!-- FRONT -->
			<div class='flipFront'>
			
			<div class='cardHeader'>
			🏅 " & _Name & " (" & _Year & ")
			</div>
			
			<div class='cardMain'>
			
			<div class='mainValue'>" & FORMAT(_Medals,"#,0") & "</div>
			
			<div class='mainSub'>Total Medals</div>
			
			</div>
			
			<div class='cardFooter'>
			Score: " & FORMAT(_Score,"#,0") & "
			</div>
			
			</div>
			
			
			<!-- BACK -->
			<div class='flipBack'>
			
			<div class='cardHeader backHeader'>
			📊 Athlete Profile
			</div>
			
			<div class='backBody'>
			
			<div>🌍 <b>" & _Country & "</b></div>
			
			<div>🏟️ " & IF(ISBLANK(_Sport),"—",_Sport) & "</div>
			
			<div>🥇 Medals: " & FORMAT(_Medals,"#,0") & "</div>
			
			<div>📈 Score: " & FORMAT(_Score,"#,0") & "</div>
			
			<div>📅 Last Games: " & _Year & "</div>
			
			</div>
			
			<div class='backHint'>
			Click to open official profile
			</div>
			
			</div>
			
			</div>
			
			</div>
			",
			
			""
			
			)
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   CONTAINER
			=====================*/
			
			.carouselBox{
			  width:100%;
			  background:#ffffff;
			  border-radius:18px;
			  border:1px solid #e5e7eb;
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			  padding:12px 14px;
			  font-family:Segoe UI;
			  overflow:hidden;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.carouselHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			  margin-bottom:8px;
			}
			
			.carouselTitle{
			  font-size:16px;
			  font-weight:900;
			  color:#111827;
			}
			
			.carouselBadge{
			  background:#dc2626;
			  color:white;
			  font-size:10px;
			  font-weight:700;
			  padding:2px 6px;
			  border-radius:4px;
			}
			
			
			/* =====================
			   CAROUSEL
			=====================*/
			
			.carousel{
			  overflow:hidden;
			  position:relative;
			}
			
			.track{
			  display:flex;
			  gap:14px;
			  width:max-content;
			  animation:scrollLoop 55s linear infinite;
			}
			
			
			/* =====================
			   CARD
			=====================*/
			
			.flipCard{
			  width:190px;
			  height:145px;
			  perspective:1200px;
			  cursor:pointer;
			}
			
			.flipInner{
			  width:100%;
			  height:100%;
			  position:relative;
			  transform-style:preserve-3d;
			  transition:.8s;
			}
			
			.flipCard:hover .flipInner{
			  transform:rotateY(180deg);
			}
			
			
			/* Faces */
			
			.flipFront,
			.flipBack{
			  position:absolute;
			  width:100%;
			  height:100%;
			  backface-visibility:hidden;
			  border-radius:14px;
			  background:#f8fafc;
			  border:1px solid #e5e7eb;
			  box-shadow:0 2px 6px rgba(0,0,0,.1);
			  display:flex;
			  flex-direction:column;
			  justify-content:space-between;
			}
			
			.flipBack{
			  transform:rotateY(180deg);
			  background:#f1f5f9;
			}
			
			
			/* Header */
			
			.cardHeader{
			  background:#dc2626;
			  color:white;
			  font-size:11px;
			  font-weight:800;
			  padding:6px 8px;
			  text-align:center;
			  white-space:nowrap;
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			.backHeader{
			  background:#2563eb;
			}
			
			
			/* Front body */
			
			.cardMain{
			  text-align:center;
			  padding:8px;
			}
			
			.mainValue{
			  font-size:28px;
			  font-weight:900;
			  color:#111827;
			}
			
			.mainSub{
			  font-size:11px;
			  color:#6b7280;
			}
			
			.cardFooter{
