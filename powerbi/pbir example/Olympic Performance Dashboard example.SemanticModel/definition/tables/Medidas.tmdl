	measure 'Era Dominance Score HTML RESPONSIVE' = ```
			
			
			
			/* =====================
			   BASE
			=====================*/
			
			VAR _Base =
			
			SUMMARIZE(
			
			    results,
			
			    calendar[Decade],
			    results[Country],
			
			    "Score", [Medal Score]
			
			)
			
			
			
			/* =====================
			   RANK + DOMINANCE
			=====================*/
			
			VAR _Ranked =
			
			ADDCOLUMNS(
			
			    _Base,
			
			    /* Rank per Decade */
			
			    "Rank",
			
			    VAR _D = calendar[Decade]
			
			    RETURN
			
			    RANKX(
			        FILTER(_Base, calendar[Decade] = _D),
			        [Score],
			        ,
			        DESC,
			        DENSE
			    ),
			
			
			    /* Decade Total */
			
			    "DecadeTotal",
			
			    VAR _D2 = calendar[Decade]
			
			    RETURN
			
			    CALCULATE(
			        SUMX(
			            FILTER(_Base, calendar[Decade] = _D2),
			            [Score]
			        )
			    )
			
			)
			
			
			
			/* =====================
			   DOMINANCE %
			=====================*/
			
			VAR _WithDom =
			
			ADDCOLUMNS(
			
			    _Ranked,
			
			    "Dominance",
			
			    DIVIDE(
			        [Score],
			        [DecadeTotal],
			        0
			    )
			
			)
			
			
			
			/* =====================
			   TOP 1
			=====================*/
			
			VAR _TopEra =
			
			FILTER(
			    _WithDom,
			    [Rank] = 1
			)
			
			
			
			/* =====================
			   HTML
			=====================*/
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   ROOT
			=====================*/
			
			html, body{
			  width:100%;
			  height:100%;
			  margin:0;
			  padding:0;
			}
			
			
			/* =====================
			   CONTAINER
			=====================*/
			
			.domBox{
			  width:100%;
			  height:100%;
			
			  background:white;
			
			  border-radius:clamp(14px,2vw,20px);
			  border:1px solid #e5e7eb;
			
			  padding:clamp(10px,2vw,14px);
			
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			
			  font-family:Segoe UI, Inter, Arial;
			
			  box-sizing:border-box;
			
			  display:flex;
			  flex-direction:column;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.domHeader{
			  margin-bottom:clamp(6px,1.5vw,10px);
			}
			
			.domTitle{
			  font-size:clamp(15px,3vw,18px);
			  font-weight:900;
			  color:#111827;
			}
			
			.domSub{
			  font-size:clamp(9px,2vw,11px);
			  color:#6b7280;
			}
			
			
			/* =====================
			   SCROLL
			=====================*/
			
			.domScroll{
			  flex:1;
			
			  overflow-y:auto;
			
			  border-radius:clamp(10px,2vw,14px);
			  border:1px solid #e5e7eb;
			}
			
			
			/* =====================
			   ROW
			=====================*/
			
			.domRow{
			  display:grid;
			
			  grid-template-columns:
			    minmax(48px,0.7fr)
			    minmax(100px,1.6fr)
			    minmax(60px,1fr)
			    minmax(80px,3fr)
			    minmax(44px,0.9fr);
			
			  align-items:center;
			
			  gap:clamp(4px,1vw,6px);
			
			  padding:clamp(6px,1.5vw,8px);
			
			  font-size:clamp(11px,2.4vw,13px);
			
			  border-bottom:1px solid #f1f5f9;
			}
			
			.domRow:hover{
			  background:#f9fafb;
			}
			
			
			/* =====================
			   COLUMNS
			=====================*/
			
			.domDec{
			  font-weight:900;
			  color:#374151;
			}
			
			.domCountry{
			  font-weight:800;
			  color:#111827;
			
			  overflow:hidden;
			  text-overflow:ellipsis;
			  white-space:nowrap;
			}
			
			.domScore{
			  font-weight:900;
			  color:#16a34a;
			
			  text-align:right;
			}
			
			
			/* =====================
			   BAR
			=====================*/
			
			.domBarWrap{
			  width:100%;
			  height:clamp(8px,1.5vw,10px);
			
			  background:#f1f5f9;
			
			  border-radius:20px;
			
			  overflow:hidden;
			}
			
			.domBar{
			  height:100%;
			  background:#dc2626;
			}
			
			
			/* =====================
			   PERCENT
			=====================*/
			
			.domPct{
			  font-size:clamp(10px,2vw,12px);
			  font-weight:800;
			  color:#dc2626;
			
			  text-align:right;
			}
			
			</style>
			
			
			<div class='domBox'>
			
			
			<!-- HEADER -->
			
			<div class='domHeader'>
			
			<div class='domTitle'>
			👑 Era Dominance Score
			</div>
			
			<div class='domSub'>
			Leading nation and share of total medal power in each decade
			</div>
			
			</div>
			
			
			<!-- LIST -->
			
			<div class='domScroll'>
			
			
			" &
			
			
			CONCATENATEX(
			
			    _TopEra,
			
			    VAR _Pct = ROUND([Dominance]*100,1)
			
			    RETURN
			
			
			"
			<div class='domRow'>
			
			<div class='domDec'>" & calendar[Decade] & "s</div>
			
			<div class='domCountry'>" & results[Country] & "</div>
			
			<div class='domScore'>" & FORMAT([Score],"#,##0") & "</div>
			
			<div class='domBarWrap'>
			  <div class='domBar' style='width:" & _Pct & "%'></div>
			</div>
			
			<div class='domPct'>" & FORMAT(_Pct,"0.0") & "%</div>
			
			</div>
			
			",
			
			"",
			
			calendar[Decade], ASC
			
			)
			
			
			&
			
			
			"
			
			</div>
			
			
			</div>
			"
			
			```
