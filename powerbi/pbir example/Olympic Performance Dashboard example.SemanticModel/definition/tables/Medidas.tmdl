	measure 'Olympic Medal Table Broadcast Fixed Header' = ```
			
			VAR _BaseTable =
			    SUMMARIZE(
			        'athlete medals',
			        'athlete medals'[NOC],
			
			        "Gold",
			            CALCULATE(
			                COUNTROWS('athlete medals'),
			                'athlete medals'[Medal] = "Gold"
			            ),
			
			        "Silver",
			            CALCULATE(
			                COUNTROWS('athlete medals'),
			                'athlete medals'[Medal] = "Silver"
			            ),
			
			        "Bronze",
			            CALCULATE(
			                COUNTROWS('athlete medals'),
			                'athlete medals'[Medal] = "Bronze"
			            ),
			
			        "Total",
			            COUNTROWS('athlete medals'),
			
			        "Score",
			            SUM('athlete medals'[Medal Value])
			    )
			
			VAR _Table =
			    ADDCOLUMNS(
			        _BaseTable,
			        "Rank",
			        RANKX(_BaseTable,[Score],,DESC,DENSE)
			    )
			
			VAR _Top10 =
			    TOPN(10,_Table,[Score],DESC)
			
			RETURN
			
			"
			<style>
			
			/* =========================
			   ANIMATIONS
			=========================*/
			
			@keyframes glowPulse {
			  0% { box-shadow:0 0 8px rgba(56,189,248,.3); }
			  50%{ box-shadow:0 0 22px rgba(56,189,248,.8); }
			  100%{ box-shadow:0 0 8px rgba(56,189,248,.3); }
			}
			
			@keyframes scanLine {
			  0% { transform:translateY(-120%); opacity:0; }
			  40%{ opacity:.7; }
			  100%{ transform:translateY(140%); opacity:0; }
			}
			
			@keyframes scrollBody {
			  0% { transform:translateY(0); }
			  100% { transform:translateY(-60%); }
			}
			
			/* =========================
			   CONTAINER
			=========================*/
			
			.tableBox {
			  background:#020617;
			  border-radius:20px;
			  padding:14px;
			  box-shadow:0 0 30px rgba(56,189,248,.45);
			  animation:glowPulse 6s infinite;
			  position:relative;
			  overflow:hidden;
			}
			
			/* Scan only on body */
			.scan {
			  position:absolute;
			  top:82px;
			  left:0;
			  right:0;
			  bottom:0;
			  background:linear-gradient(
			    transparent,
			    rgba(56,189,248,.12),
			    transparent
			  );
			  animation:scanLine 7s linear infinite;
			  pointer-events:none;
			  z-index:1;
			}
			
			/* =========================
			   HEADER
			=========================*/
			
			.tableHeader {
			  font-size:20px;
			  font-weight:900;
			  color:#38bdf8;
			  margin-bottom:6px;
			  text-shadow:0 0 8px rgba(56,189,248,.8);
			  display:flex;
			  align-items:center;
			  gap:10px;
			  position:relative;
			  z-index:3;
			}
			
			.medalIcons {
			  font-size:20px;
			}
			
			/* =========================
			   TABLE
			=========================*/
			
			.tableWrap {
			  position:relative;
			  z-index:2;
			}
			
			/* Fixed header table */
			.tableHead {
			  width:100%;
			  border-collapse:collapse;
			  font-size:13px;
			  color:#94a3b8;
			}
			
			.tableHead th {
			  padding:6px;
			  border-bottom:1px solid #1e293b;
			  text-align:left;
			}
			
			/* Scroll body */
			.bodyWrap {
			  max-height:220px;
			  overflow:hidden;
			}
			
			.tableBody {
			  width:100%;
			  border-collapse:collapse;
			  font-size:13px;
			  color:#e5f3ff;
			}
			
			.tableBody td {
			  padding:6px;
			  border-bottom:1px solid #020617;
			}
			
			.scrollContent {
			  animation:scrollBody 26s linear infinite;
			}
			
			/* Top 3 */
			.rank1 { background:rgba(250,204,21,.18); }
			.rank2 { background:rgba(148,163,184,.18); }
			.rank3 { background:rgba(244,114,182,.18); }
			
			.rankCol {
			  color:#38bdf8;
			  font-weight:800;
			}
			
			</style>
			
			
			<div style='width:100%;font-family:Segoe UI;'>
			
			<div class='tableBox'>
			
			<div class='scan'></div>
			
			
			<!-- HEADER -->
			<div class='tableHeader'>
			
			<span>🏆 MEDAL TABLE — LIVE RANKING</span>
			
			<span class='medalIcons'>🥇🥈🥉</span>
			
			</div>
			
			
			<!-- TABLE -->
			<div class='tableWrap'>
			
			
			<!-- FIXED HEADER -->
			<table class='tableHead'>
			
			<thead>
			<tr>
			  <th>#</th>
			  <th>NOC</th>
			  <th>🥇</th>
			  <th>🥈</th>
			  <th>🥉</th>
			  <th>Total</th>
			  <th>Score</th>
			</tr>
			</thead>
			
			</table>
			
			
			<!-- BODY -->
			<div class='bodyWrap'>
			
			<table class='tableBody'>
			
			<tbody class='scrollContent'>
			" &
			
			CONCATENATEX(
			
			    _Top10,
			
			    VAR _Rank = [Rank]
			
			    VAR _Class =
			        IF(
			            _Rank=1,"rank1",
			            IF(_Rank=2,"rank2",
			            IF(_Rank=3,"rank3",""))
			        )
			
			    RETURN
			
			"
			<tr class='" & _Class & "'>
			
			  <td class='rankCol'>" & _Rank & "</td>
			
			  <td><b>" & [NOC] & "</b></td>
			
			  <td>" & [Gold] & "</td>
			
			  <td>" & [Silver] & "</td>
			
			  <td>" & [Bronze] & "</td>
			
			  <td><b>" & [Total] & "</b></td>
			
			  <td style='color:#38bdf8;font-weight:800;'>" &
			        FORMAT([Score],"#,0") &
			  "</td>
			
			</tr>
			",
			
			"",
			[Rank], ASC
			
			)
			
			&
			
			"
			</tbody>
			
			</table>
			
			</div>
			
			</div>
			
			</div>
			
			</div>
			"
			
			```
		displayFolder: Dash 1
		lineageTag: 1683f9af-7934-45b0-af04-9567e9c197f5

	measure 'Olympic Flip Card Test' = ```
			
			VAR _Total = FORMAT([Total Medals], "#,0")
			
			VAR _TopCountry =
			    CALCULATE(
			        SELECTEDVALUE(results[NOC]),
			        TOPN(1,ALL(results[NOC]),[Medal Score],DESC)
			    )
			
			VAR _Score =
			    CALCULATE([Medal Score],results[NOC]=_TopCountry)
			
			RETURN
			
			"
			<style>
			
			/* =====================
			   FLIP EFFECT
			=====================*/
			
			.flipCard {
			  background: transparent;
			  width: 220px;
			  height: 140px;
			  perspective: 1200px;
			}
			
			.flipInner {
			  position: relative;
			  width: 100%;
			  height: 100%;
			  text-align: center;
			  transition: transform 0.9s cubic-bezier(.4,.2,.2,1);
			  transform-style: preserve-3d;
			}
			
			/* Hover flip */
			.flipCard:hover .flipInner {
			  transform: rotateY(180deg);
			}
			
			/* Faces */
			.flipFront,
			.flipBack {
			  position: absolute;
			  width: 100%;
			  height: 100%;
			  backface-visibility: hidden;
			  border-radius: 16px;
			  overflow: hidden;
			  box-shadow:0 0 18px rgba(56,189,248,.5);
			}
			
			/* FRONT */
			.flipFront {
			  background: linear-gradient(180deg,#020617,#020617);
			  color: white;
			  border:1px solid #38bdf8;
			}
			
			/* BACK */
			.flipBack {
			  background: linear-gradient(180deg,#020617,#020617);
			  color: white;
			  transform: rotateY(180deg);
			  border:1px solid #22c55e;
			}
			
			/* Header */
			.flipHeader {
			  background:#0284c7;
			  padding:6px;
			  font-size:12px;
			  font-weight:800;
			  text-transform:uppercase;
			}
			
			/* Content */
			.flipContent {
			  padding:12px;
			}
			
			/* Glow */
			@keyframes glow {
			  0% { box-shadow:0 0 6px rgba(56,189,248,.4); }
			  50%{ box-shadow:0 0 16px rgba(56,189,248,.9); }
			  100%{ box-shadow:0 0 6px rgba(56,189,248,.4); }
			}
			
			.flipFront,
			.flipBack {
			  animation:glow 4s infinite;
			}
			
			</style>
			
			
			<div style='font-family:Segoe UI;'>
			
			<div class='flipCard'>
			
			<div class='flipInner'>
			
			<!-- FRONT -->
			<div class='flipFront'>
			
			<div class='flipHeader'>
			🏅 TOTAL MEDALS
			</div>
			
			<div class='flipContent'>
			
			<div style='font-size:34px;font-weight:900;color:#e5f3ff;'>
			" & _Total & "
			</div>
			
			<div style='font-size:12px;color:#94a3b8;'>
			All Olympic Games
			</div>
			
			</div>
			
			</div>
			
			
			<!-- BACK -->
			<div class='flipBack'>
			
			<div class='flipHeader' style='background:#22c55e;color:#020617;'>
			📊 TOP NATION
			</div>
			
			<div class='flipContent'>
			
			<div style='font-size:20px;font-weight:800;'>
			" & _TopCountry & "
			</div>
			
			<div style='font-size:13px;color:#22c55e;margin-top:4px;'>
			Score: " & FORMAT(_Score,"#,0") & "
			</div>
			
			<div style='font-size:11px;color:#94a3b8;margin-top:8px;'>
			Leading Olympic power
			</div>
			
			</div>
			
			</div>
			
			</div>
			
			</div>
			
			</div>
			"
			
			```
