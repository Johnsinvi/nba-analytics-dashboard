	measure 'Olympic Athlete Cards ESPN GROUP v9' = ```
			
			
			VAR _Base =
			
			FILTER(
			
			    ADDCOLUMNS(
			
			        SUMMARIZE(
			            results,
			            results[athlete_full_name],
			            results[NOC],
			            results[Country]
			        ),
			
			        /* TOTAL MEDALS */
			        "TotalMedals",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] IN {"Gold","Silver","Bronze"}
			        ),
			
			        /* GOLD */
			        "Gold",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Gold"
			        ),
			
			        /* SILVER */
			        "Silver",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Silver"
			        ),
			
			        /* BRONZE */
			        "Bronze",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Bronze"
			        ),
			
			        /* LAST YEAR */
			        "LastYear",
			
			        VAR _LastSlug =
			            CALCULATE(
			                MAX(results[Game Slug])
			            )
			
			        RETURN
			            CALCULATE(
			                MAX(hosts[Year]),
			                hosts[Game Slug] = _LastSlug
			            ),
			
			        /* TOP SPORT */
			        "TopSport",
			
			        VAR _Athlete =
			            SELECTEDVALUE(results[athlete_full_name])
			
			        VAR _SportTable =
			
			            SUMMARIZE(
			                FILTER(
			                    results,
			                    results[athlete_full_name] = _Athlete
			                ),
			                results[Discipline],
			                "Qtd", COUNTROWS(results)
			            )
			
			        RETURN
			            MAXX(
			                TOPN(1,_SportTable,[Qtd],DESC),
			                [Discipline]
			            ),
			
			        /* URL */
			        "URL",
			        CALCULATE(
			            MAX(results[athlete_url])
			        ),
			
			        /* FLAG */
			        "Flag",
			        SWITCH(
			            results[NOC],
			            "USA","🇺🇸","BRA","🇧🇷","GER","🇩🇪","FRA","🇫🇷","GBR","🇬🇧",
			            "CHN","🇨🇳","JPN","🇯🇵","RUS","🇷🇺","ITA","🇮🇹","ESP","🇪🇸",
			            "AUS","🇦🇺","CAN","🇨🇦","KOR","🇰🇷","NED","🇳🇱","SWE","🇸🇪",
			            "NOR","🇳🇴","POL","🇵🇱","ARG","🇦🇷","MEX","🇲🇽","POR","🇵🇹",
			            "🏳️"
			        )
			
			    ),
			
			    NOT ISBLANK(results[athlete_full_name]) &&
			    results[athlete_full_name] <> ""
			)
			
			
			
			VAR _Top =
			    TOPN(25,_Base,[TotalMedals],DESC)
			
			
			
			VAR _Cards =
			
			CONCATENATEX(
			
			    _Top,
			
			"
			
			<a href='https://www.olympics.com" & [URL] & "'
			   target='_blank'
			   class='cardLink'>
			
			<div class='card'>
			
			
			<!-- FRONT -->
			<div class='front'>
			
			<div class='name'>" & [athlete_full_name] & "</div>
			
			<div class='sport'>
			" & IF(ISBLANK([TopSport]),"Multiple Sports",[TopSport]) & "
			</div>
			
			<div class='country'>
			" & [Flag] & " " & [Country] & "
			</div>
			
			<div class='medalBadge'>
			🏅 " & FORMAT([TotalMedals],"#,0") & "
			</div>
			
			<div class='year'>
			Last Games: " & [LastYear] & "
			</div>
			
			</div>
			
			
			<!-- BACK -->
			<div class='back'>
			
			<div class='backHeader'>
			ATHLETE STATS
			</div>
			
			<div class='backBody'>
			
			<div class='line'>🥇 Gold: " & [Gold] & "</div>
			<div class='line'>🥈 Silver: " & [Silver] & "</div>
			<div class='line'>🥉 Bronze: " & [Bronze] & "</div>
			
			<div class='line'>🏟️ Main Sport: " & [TopSport] & "</div>
			
			</div>
			
			<div class='backFooter'>
			Official Olympic Profile
			</div>
			
			</div>
			
			</div>
			
			</a>
			
			",
			
			""
			
			)
			
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   CONTAINER
			=====================*/
			
			.olympicContainer{
			  width:100%;
			  max-width:730px;
			  height:168px;
			
			  background:transparent;
			
			  position:relative;
			
			  padding:4px;
			
			  box-sizing:border-box;
			
			  overflow:hidden;
			}
			
			
			/* =====================
			   HINT
			=====================*/
			
			.hoverHint{
			  position:absolute;
			  top:4px;
			  right:8px;
			
			  font-size:9px;
			  font-weight:600;
			
			  color:#6b7280;
			
			  background:rgba(255,255,255,0.35);
			  backdrop-filter:blur(4px);
			
			  padding:3px 6px;
			  border-radius:7px;
			}
			
			
			/* =====================
			   TITLE
			=====================*/
			
			.groupTitle{
			  font-size:15px;
			  font-weight:900;
			  color:#111827;
			
			  margin-bottom:2px;
			}
			
			.groupSub{
			  font-size:9px;
			  color:#6b7280;
			  margin-bottom:2px;
			}
			
			
			/* =====================
			   SCROLL
			=====================*/
			
			.scrollOuter{
			  overflow-x:auto;
			  overflow-y:hidden;
			
			  width:100%;
			  height:128px;
			}
			
			.scrollWrap{
			  display:flex;
			  gap:10px;
			  padding:3px;
			
			  width:max-content;
			
			  animation:autoScroll 70s linear infinite;
			}
			
			.scrollOuter:hover .scrollWrap{
			  animation-play-state:paused;
			}
			
			
			@keyframes autoScroll{
			  0%{ transform:translateX(0); }
			  100%{ transform:translateX(-50%); }
			}
			
			
			/* =====================
			   CARD
			=====================*/
			
			.card{
			  min-width:190px;
			  height:120px;
			
			  background:rgba(255,255,255,0.6);
			  backdrop-filter:blur(6px);
			
			  border-radius:12px;
			
			  border:1px solid rgba(255,255,255,0.25);
			
			  box-shadow:0 2px 8px rgba(0,0,0,.12);
			
			  position:relative;
			  overflow:hidden;
			
			  transition:.3s ease;
			}
			
			.card:hover{
			  transform:translateY(-4px) scale(1.02);
			  box-shadow:0 10px 18px rgba(0,0,0,.22);
			}
			
			
			/* FRONT */
			
			.front{
			  height:100%;
			  padding:8px;
			
			  display:flex;
			  flex-direction:column;
			  justify-content:space-between;
			}
			
			.name{
			  font-size:12px;
			  font-weight:900;
			  color:#111827;
			
			  white-space:nowrap;
			  overflow:hidden;
			  text-overflow:ellipsis;
			}
			
			.sport{
			  font-size:10px;
			  font-weight:800;
			  color:#2563eb;
			}
			
			.country{
			  font-size:10px;
			  font-weight:700;
			  color:#374151;
			}
			
			.medalBadge{
			  background:rgba(254,226,226,0.7);
			  color:#dc2626;
			
			  font-size:10px;
			  font-weight:900;
			
			  padding:2px 5px;
			  border-radius:6px;
			
			  width:fit-content;
			}
			
			.year{
			  font-size:9px;
			  color:#6b7280;
			}
			
			
			/* BACK */
			
			.back{
			  position:absolute;
			  bottom:-100%;
			  left:0;
			
			  width:100%;
			  height:100%;
			
			  background:rgba(248,250,252,0.9);
			
			  backdrop-filter:blur(6px);
			
			  padding:9px;
			
			  display:flex;
			  flex-direction:column;
			  justify-content:space-between;
			
			  transition:.45s ease;
			
			  border-top:3px solid #dc2626;
			}
			
			.card:hover .back{
			  bottom:0;
			}
			
			
			.backHeader{
			  background:#dc2626;
			  color:white;
			
			  font-size:9px;
			  font-weight:900;
			
			  text-align:center;
			
			  padding:2px;
			  border-radius:5px;
			}
			
			.backBody{
			  font-size:10px;
			  line-height:1.3;
			}
			
			.line{
			  margin-bottom:2px;
			}
			
			.backFooter{
			  font-size:8px;
			  text-align:center;
			  color:#6b7280;
			
			  border-top:1px solid #e5e7eb;
			  padding-top:2px;
			}
			
			
			/* =====================
			   RESPONSIVE
			=====================*/
			
			@media(max-width:600px){
			
			  .card{
			    min-width:160px;
			    height:110px;
			  }
			
			  .groupTitle{
			    font-size:14px;
			  }
			
			  .hoverHint{
			    font-size:8px;
			  }
			
			}
			
			</style>
			
			
			
			<div class='olympicContainer'>
			
			
			<div class='hoverHint'>
			Hover over the cards to see details
			</div>
			
			
			<div>
			
			  <div class='groupTitle'>
			  🏅 Top Olympic Athletes
			  </div>
			
			  <div class='groupSub'>
			  Leading medalists across Olympic history
			  </div>
			
			</div>
			
			
			<div class='scrollOuter'>
			
			  <div class='scrollWrap'>
			
			  " & _Cards & _Cards & "
			
			  </div>
			
			</div>
			
			</div>
			"
			
			```
		displayFolder: Dash 1
