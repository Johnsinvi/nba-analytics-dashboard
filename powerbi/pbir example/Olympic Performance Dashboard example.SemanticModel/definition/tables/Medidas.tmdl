	measure 'Olympic Country Tooltip HTML v5' = ```
			
			
			/* ==========================
			   BASIC DATA
			========================== */
			
			VAR _Country =
			SELECTEDVALUE(results[Country])
			
			VAR _Score =
			FORMAT([Medal Score],"#,0")
			
			VAR _Total =
			FORMAT([Total Medals],"#,0")
			
			VAR _Gold =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    'athlete medals'[Medal] = "Gold"
			)
			
			VAR _Silver =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    'athlete medals'[Medal] = "Silver"
			)
			
			VAR _Bronze =
			CALCULATE(
			    COUNTROWS('athlete medals'),
			    'athlete medals'[Medal] = "Bronze"
			)
			
			VAR _TopDiscipline =
			CALCULATE(
			    SELECTEDVALUE(results[Discipline]),
			    TOPN(
			        1,
			        ALL(results[Discipline]),
			        [Total Medals],
			        DESC
			    )
			)
			
			VAR _Season =
			SELECTEDVALUE(hosts[Season],"All")
			
			
			/* ==========================
			   HTML OUTPUT
			========================== */
			
			RETURN
			
			"
			<div style='
			width:320px;
			height:386px;
			background:#ffffff;
			border-radius:16px;
			border:1px solid #e5e7eb;
			box-shadow:0 4px 12px rgba(0,0,0,.18);
			padding:14px;
			font-family:Segoe UI;
			display:flex;
			flex-direction:column;
			justify-content:space-between;
			'>
			
			
			<!-- HEADER -->
			<div style='border-bottom:2px solid #dc2626;padding-bottom:6px;margin-bottom:6px;'>
			
			<div style='
			font-size:17px;
			font-weight:900;
			color:#111827;
			white-space:nowrap;
			overflow:hidden;
			text-overflow:ellipsis;
			'>
			🌍 " & _Country & "
			</div>
			
			<div style='
			font-size:11px;
			font-weight:800;
			color:#dc2626;
			text-transform:uppercase;
			'>
			" & _Season & " • Performance Summary
			</div>
			
			</div>
			
			
			<!-- KPIs -->
			<div style='display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:10px;'>
			
			
			<div>
			<div style='font-size:11px;color:#6b7280;'>Medal Score</div>
			<div style='font-size:20px;font-weight:900;color:#16a34a;'>" & _Score & "</div>
			</div>
			
			
			<div>
			<div style='font-size:11px;color:#6b7280;'>Total Medals</div>
			<div style='font-size:20px;font-weight:900;color:#111827;'>" & _Total & "</div>
			</div>
			
			
			<div>
			<div style='font-size:11px;color:#6b7280;'>Gold</div>
			<div style='font-size:16px;font-weight:800;'>🥇 " & _Gold & "</div>
			</div>
			
			
			<div>
			<div style='font-size:11px;color:#6b7280;'>Silver / Bronze</div>
			<div style='font-size:14px;font-weight:700;'>
			🥈 " & _Silver & " / 🥉 " & _Bronze & "
			</div>
			</div>
			
			</div>
			
			
			<!-- EMPTY SPACE (CHART PLACEHOLDER) -->
			<div style='
			width:100%;
			height:130px;
			background:#f8fafc;
			border:1px dashed #e5e7eb;
			border-radius:10px;
			display:flex;
			align-items:center;
			justify-content:center;
			margin-bottom:10px;
			color:#9ca3af;
			font-size:12px;
			font-weight:600;
			'>
			
			
			
			</div>
			
			
			<!-- FOOTER -->
			<div style='
			border-top:1px solid #e5e7eb;
			padding-top:6px;
			font-size:12px;
			color:#374151;
			white-space:nowrap;
			overflow:hidden;
			text-overflow:ellipsis;
			'>
			🏟️ Top Discipline: <b>" & _TopDiscipline & "</b>
			</div>
			
			</div>
			"
			
			```
		displayFolder: Dash 2
		lineageTag: 4a4c91cb-8c09-4d59-844e-576947e570f6

	measure 'Olympic Comparison Table ESPN – Page 2' = ```
			
			
			VAR BaseTable =
			
			SUMMARIZE(
			
			    results,
			    results[Country],
			    results[NOC],
			
			    "Gold",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Gold"
			        ),
			
			    "Silver",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Silver"
			        ),
			
			    "Bronze",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] = "Bronze"
			        ),
			
			    "Total",
			        CALCULATE(
			            COUNTROWS(results),
			            results[Medal (Raw)] IN {"Gold","Silver","Bronze"}
			        ),
			
			    "Score",
			        CALCULATE(
			            [Medal Score]
			        )
			)
			
			
			VAR RankedTable =
			
			ADDCOLUMNS(
			
			    BaseTable,
			
			    "Rank",
			    RANKX(
			        BaseTable,
			        [Score],
			        ,
			        DESC,
			        DENSE
			    )
			)
			
			
			VAR TopCountries =
			    TOPN(15,RankedTable,[Score],DESC)
			
			
			RETURN
			
			
			"
			<style>
			
			/* =====================
			   TABLE CONTAINER
			=====================*/
			
			.compBox{
			  background:#ffffff;
			  border-radius:18px;
			  border:1px solid #e5e7eb;
			  padding:14px;
			  box-shadow:0 2px 8px rgba(0,0,0,.08);
			
			  font-family:Segoe UI;
			}
			
			
			/* =====================
			   HEADER
			=====================*/
			
			.compHeader{
			  display:flex;
			  justify-content:space-between;
			  align-items:center;
			
			  margin-bottom:10px;
			}
			
			.compTitle{
			  font-size:20px;
			  font-weight:900;
			  color:#111827;
			}
			
			.compBadge{
			  background:#dc2626;
			  color:white;
			
			  font-size:11px;
			  font-weight:800;
			
			  padding:2px 6px;
			  border-radius:4px;
			}
			
			
			/* =====================
			   TABLE
			=====================*/
			
			.tableWrap{
			  overflow:hidden;
			  border-radius:12px;
			  border:1px solid #e5e7eb;
			}
			
			.compTable{
			  width:100%;
			  border-collapse:collapse;
			  font-size:13px;
			}
			
			
			/* HEADER */
			
			.compTable thead{
			  background:#f1f5f9;
			}
			
			.compTable th{
			  padding:8px 6px;
			
			  text-align:left;
			
			  font-weight:800;
			  color:#374151;
			
			  border-bottom:1px solid #e5e7eb;
			}
			
			
			/* BODY */
			
			.compTable td{
			  padding:7px 6px;
			  border-bottom:1px solid #f1f5f9;
			
			  color:#111827;
			}
			
			.compTable tr:hover{
			  background:#f9fafb;
			}
			
			
			/* RANK */
			
			.rankCol{
			  font-weight:900;
			  color:#dc2626;
			}
			
			
			/* COUNTRY */
			
			.countryCol{
			  font-weight:800;
			}
			
			
			/* SCORE */
			
			.scoreCol{
			  font-weight:900;
			  color:#16a34a;
			}
			
			
			/* PODIUM */
			
			.rank1{ background:rgba(250,204,21,.15); }
			.rank2{ background:rgba(209,213,219,.18); }
			.rank3{ background:rgba(192,132,252,.15); }
			
			</style>
			
			
			<div class='compBox'>
			
			
			<!-- HEADER -->
			<div class='compHeader'>
			
			<div class='compTitle'>
			🌍 Country Performance Comparison
			</div>
			
			<div class='compBadge'>
			LIVE
			</div>
			
			</div>
			
			
			<!-- TABLE -->
			<div class='tableWrap'>
			
			
			<table class='compTable'>
			
			
			<thead>
			
			<tr>
			  <th>#</th>
			  <th>Country</th>
			  <th>🥇</th>
			  <th>🥈</th>
			  <th>🥉</th>
			  <th>Total</th>
			  <th>Score</th>
			</tr>
			
			</thead>
			
			
			<tbody>
			
			" &
			
			
			CONCATENATEX(
			
			    TopCountries,
			
			    VAR R = [Rank]
			
			    VAR Class =
			        IF(
			            R=1,"rank1",
			            IF(R=2,"rank2",
			            IF(R=3,"rank3",""))
			        )
			
			    RETURN
			
			"
			<tr class='" & Class & "'>
			
			  <td class='rankCol'>" & R & "</td>
			
			  <td class='countryCol'>" & [Country] & "</td>
			
			  <td>" & [Gold] & "</td>
			
			  <td>" & [Silver] & "</td>
			
			  <td>" & [Bronze] & "</td>
			
			  <td><b>" & [Total] & "</b></td>
			
			  <td class='scoreCol'>" &
			        FORMAT([Score],"#,0") &
			  "</td>
			
			</tr>
			",
			
			"",
			
			[Rank], ASC
			
			)
			
			
			&
			
			"
			
			</tbody>
			
			</table>
			
			</div>
			
