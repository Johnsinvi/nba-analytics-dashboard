	measure 'Olympic Ranking Table' = ```
			
			VAR TableHTML =
			
			CONCATENATEX(
			
			    TOPN(
			        20,
			        ADDCOLUMNS(
			            VALUES(results[NOC]),
			
			            "Rank", [Rank Country],
			            "Score", [Medal Score],
			            "Gold", [Gold Medals],
			            "Silver", [Silver Medals],
			            "Bronze", [Bronze Medals]
			        ),
			        [Rank],
			        ASC
			    ),
			
			    VAR _Rank = [Rank]
			    VAR _NOC = results[NOC]
			    VAR _Score = FORMAT([Score],"#,0")
			    VAR _Gold = FORMAT([Gold],"0")
			    VAR _Silver = FORMAT([Silver],"0")
			    VAR _Bronze = FORMAT([Bronze],"0")
			
			    VAR _BG =
			        IF(_Rank=1,"#fef3c7",
			        IF(_Rank=2,"#e5e7eb",
			        IF(_Rank=3,"#fde68a","#ffffff")))
			
			    VAR _Icon =
			        IF(_Rank=1,"🥇",
			        IF(_Rank=2,"🥈",
			        IF(_Rank=3,"🥉",_Rank)))
			
			    RETURN
			
			    "<tr style='background:" & _BG & ";border-bottom:1px solid #e5e7eb;'>
			
			        <td style='padding:8px;font-weight:700;text-align:center;'>" &
			            _Icon &
			        "</td>
			
			        <td style='padding:8px;font-weight:600;'>" &
			            _NOC &
			        "</td>
			
			        <td style='padding:8px;text-align:right;font-weight:700;'>" &
			            _Score &
			        "</td>
			
			        <td style='padding:8px;text-align:center;color:#f59e0b;'>" &
			            _Gold &
			        "</td>
			
			        <td style='padding:8px;text-align:center;color:#9ca3af;'>" &
			            _Silver &
			        "</td>
			
			        <td style='padding:8px;text-align:center;color:#b45309;'>" &
			            _Bronze &
			        "</td>
			
			    </tr>",
			
			    ""
			)
			
			RETURN
			
			"<div style='font-family:Segoe UI;background:#ffffff;
			border-radius:18px;box-shadow:0 6px 14px rgba(0,0,0,0.15);
			padding:14px;'>
			
			<div style='font-size:16px;font-weight:700;color:#111827;
			margin-bottom:10px;'>
			🏆 Olympic Nations Ranking
			</div>
			
			<div style='overflow-x:auto;'>
			
			<table style='width:100%;border-collapse:collapse;font-size:13px;'>
			
			<thead>
			
			<tr style='background:#111827;color:white;'>
			
			<th style='padding:8px;'>#</th>
			<th style='padding:8px;text-align:left;'>Nation</th>
			<th style='padding:8px;text-align:right;'>Score</th>
			<th style='padding:8px;'>🥇</th>
			<th style='padding:8px;'>🥈</th>
			<th style='padding:8px;'>🥉</th>
			
			</tr>
			
			</thead>
			
			<tbody>" &
			
			TableHTML &
			
			"</tbody>
			
			</table>
			
			</div>
			
			</div>"
			
			```
		displayFolder: Dash 1
		lineageTag: 5ff8189d-6596-428e-bcc1-1cda3150e07b

